<Application x:Class="AltKey.Tools.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 메인 앱과 동일한 기본 리소스/테마 팔레트를 공유해 도구 창의 시각적 일관성을 유지합니다. -->
                <ResourceDictionary Source="/AltKey;component/Themes/Generic.xaml"/>
                <!-- 초기 테마는 코드(App.xaml.cs)에서 사용자 설정 기준으로 다시 교체합니다. -->
                <ResourceDictionary Source="/AltKey;component/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/AltKey;component/Themes/SettingsControls.xaml"/>
                <!-- Phase 1: 도구 창에서 선택 적용할 Fluent 스타일 리소스 -->
                <ResourceDictionary Source="/AltKey;component/Themes/FluentControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 메인 앱과 동일한 한글 우선 폰트 체인으로 가독성을 맞춥니다. -->
            <FontFamily x:Key="AppFontFamily">NanumGothic, Malgun Gothic, Segoe UI</FontFamily>
            <Style TargetType="Control">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Style>
            <Style TargetType="Window">
                <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
