<Window x:Class="AltKey.Tools.ProfileMappingReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="프로필 매핑 편집 검토"
        Width="860"
        Height="640"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        KeyboardNavigation.TabNavigation="Cycle"
        AutomationProperties.Name="프로필 매핑 편집 검토 창">
    <Window.Resources>
        <!-- 검토 창 내부의 카드 단위를 통일해 섹션 간 경계를 시각적으로 분리합니다. -->
        <Style x:Key="ReviewSectionCardStyle" TargetType="Border" BasedOn="{StaticResource FluentCardBorderStyle}">
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style TargetType="DataGrid" BasedOn="{StaticResource FluentDataGridStyle}" />
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}" />
    </Window.Resources>

    <Border Margin="14"
            Padding="16"
            Background="{DynamicResource SettingsBg}"
            BorderBrush="{DynamicResource SettingsBorder}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Text="프로필 매핑 편집 검토"
                       AutomationProperties.Name="검토 창 제목"/>

            <TextBlock Grid.Row="1"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap"
                       Text="이 창은 구현 변경이 아닌 검토를 위한 화면입니다. 현재 매핑 구조를 점검하고 별도 편집 도구 승격의 우선순위를 판단합니다."
                       AutomationProperties.Name="검토 목적 안내"/>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ReviewSectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="1. 현재 구성 요약"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   AutomationProperties.Name="요약 섹션 제목"/>
                        <TextBlock Margin="0,6,0,2"
                                   Text="{Binding SummaryText}"
                                   TextWrapping="Wrap"
                                   AutomationProperties.Name="현재 구성 요약 값"/>
                        <TextBlock Text="{Binding RiskText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SettingsFgSub}"
                                   AutomationProperties.Name="리스크 요약 값"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource ReviewSectionCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Margin="0,0,0,8"
                                   Text="2. 매핑 목록"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   AutomationProperties.Name="매핑 목록 섹션 제목"/>

                        <DataGrid x:Name="ReviewGrid"
                                  Grid.Row="1"
                                  ItemsSource="{Binding Entries}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  KeyboardNavigation.TabIndex="0"
                                  AutomationProperties.Name="프로필 매핑 목록">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="프로세스 이름" Binding="{Binding ProcessName}" Width="2*" />
                                <DataGridTextColumn Header="레이아웃 이름" Binding="{Binding LayoutName}" Width="2*" />
                                <DataGridTextColumn Header="검토 상태" Binding="{Binding Status}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,0,0,0"
                        Padding="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource SettingsBorder}"
                        Background="{DynamicResource SettingsHighlight}"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="3. 판단 결과"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"
                                   AutomationProperties.Name="판단 결과 섹션 제목"/>
                        <TextBlock Text="{Binding DecisionText}"
                                   TextWrapping="Wrap"
                                   AutomationProperties.Name="2단계 후보 판단 결과"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Button Grid.Row="3"
                    Content="닫기 (Esc)"
                    Width="140"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0"
                    KeyboardNavigation.TabIndex="1"
                    Click="OnClose"
                    AutomationProperties.Name="검토 창 닫기 버튼"
                    AutomationProperties.HelpText="프로필 매핑 검토 창을 닫고 이전 화면으로 돌아갑니다."/>
        </Grid>
    </Border>
</Window>
