<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 페이즈 1: 기존 Settings* 팔레트를 감싼 Fluent 별칭 리소스(옵트인 전용) -->
    <Thickness x:Key="FluentContentPadding">12,8</Thickness>
    <Thickness x:Key="FluentSectionSpacing">0,0,0,12</Thickness>
    <CornerRadius x:Key="FluentCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="FluentLargeCornerRadius">12</CornerRadius>

    <SolidColorBrush x:Key="FluentSurfaceBrush" Color="{Binding Color, Source={StaticResource SettingsBg}}"/>
    <SolidColorBrush x:Key="FluentCardBrush" Color="{Binding Color, Source={StaticResource SettingsHighlight}}"/>
    <SolidColorBrush x:Key="FluentTextBrush" Color="{Binding Color, Source={StaticResource SettingsFg}}"/>
    <SolidColorBrush x:Key="FluentSubtleTextBrush" Color="{Binding Color, Source={StaticResource SettingsFgSub}}"/>
    <SolidColorBrush x:Key="FluentBorderBrush" Color="{Binding Color, Source={StaticResource SettingsBorder}}"/>

    <!-- 기존 전역 스타일을 유지하면서 창에서 선택 적용할 수 있도록 Keyed 스타일만 추가 -->
    <Style x:Key="FluentButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Padding" Value="{StaticResource FluentContentPadding}"/>
        <Setter Property="MinHeight" Value="32"/>
    </Style>

    <Style x:Key="FluentTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="32"/>
    </Style>

    <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="MinHeight" Value="32"/>
    </Style>

    <Style x:Key="FluentTabControlStyle" TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
        <Setter Property="Padding" Value="0,4,0,0"/>
    </Style>

    <Style x:Key="FluentDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="RowHeight" Value="32"/>
        <Setter Property="ColumnHeaderHeight" Value="34"/>
    </Style>

    <Style x:Key="FluentCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource FluentCardBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FluentBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerRadius}"/>
        <Setter Property="Padding" Value="12"/>
    </Style>
</ResourceDictionary>
