<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 접근성: 설정 계열 창이 시스템 기본 흰 배경으로 돌아가지 않도록 공통 표면 스타일을 공유합니다. -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
                <!-- 접근성: 선택 탭 표면이 밝아지는 테마에서도 제목이 사라지지 않도록 전경색을 고정한다. -->
                <Setter Property="Foreground" Value="Black"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <!-- 접근성: 닫힌 ComboBox 선택값은 세 테마 모두 밝은 표면에 그려져 검은 글자가 가장 안정적으로 읽힌다. -->
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="TextElement.Foreground" Value="Black"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <!-- 접근성: 닫힌 상태 ComboBox 본문도 이 선택 항목 전경색을 재사용하므로 검은 글자를 유지한다. -->
                <Setter Property="Foreground" Value="Black"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="RowBackground" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource SettingsBorder}"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
