<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 키보드 컨테이너: 흰 키와 구별되도록 밝은 회색 (iOS 키보드 스타일) -->
    <SolidColorBrush x:Key="KeyboardBg"   Color="#CCE8E8EC"/>
    <!-- 키 배경: 순수 흰색으로 컨테이너 대비 명확히 -->
    <SolidColorBrush x:Key="KeyBg"        Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="KeyBgHover"   Color="#FFD4D4D8"/>
    <SolidColorBrush x:Key="KeyBgPressed" Color="#FFBCBCC4"/>
    <!-- Sticky: 채도 낮춘 슬레이트 블루 (라이트 배경에서 자연스럽게) -->
    <SolidColorBrush x:Key="KeyBgSticky"  Color="#404A8FDE"/>
    <SolidColorBrush x:Key="KeyFg"        Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="KeyFgSticky"  Color="#FF1A4FC4"/>
    <!-- 흰 키의 경계선이 보이도록 약간 강화 -->
    <SolidColorBrush x:Key="KeyBorder"    Color="#1E000000"/>
    <SolidColorBrush x:Key="KeyShadow"    Color="#1E000000"/>
    <!-- 제목/버튼용: 라이트 배경에서 읽히는 진한 회색 -->
    <SolidColorBrush x:Key="TitleFg"      Color="#FF505050"/>
    <!-- 전체 창 배경: 상단/하단 바가 하얗고 투명하게 보이도록 -->
    <SolidColorBrush x:Key="WindowBg"     Color="#AAFFFFFF"/>
</ResourceDictionary>
