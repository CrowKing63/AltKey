<Application x:Class="AltKey.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AltKey">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 구조 리소스 (크기/폰트/애니메이션/컨트롤 스타일) -->
                <ResourceDictionary Source="/AltKey;component/Themes/Generic.xaml"/>
                <!-- 활성 테마 — ThemeService가 런타임에 교체 -->
                <ResourceDictionary Source="/AltKey;component/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
