<UserControl x:Class="AltKey.Views.ClipboardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AltKey.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ClipboardViewModel}">

    <Border Background="{DynamicResource PanelBg}"
            BorderBrush="{DynamicResource PanelBorder}"
            BorderThickness="0,0,1,1"
            CornerRadius="0,0,8,0"
            Padding="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid Grid.Row="0" Margin="4,4,4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="클립보드"
                           Grid.Column="0"
                           FontSize="11"
                           Opacity="0.6"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PanelFg}"/>
                <Button Content="전체 삭제"
                        Grid.Column="1"
                        Command="{Binding ClearHistoryCommand}"
                        Padding="4,2"
                        FontSize="10"
                        Background="Transparent"
                        Foreground="{DynamicResource PanelFg}"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button Content="✕"
                        Grid.Column="2"
                        Command="{Binding CloseCommand}"
                        Width="20" Height="20"
                        Margin="4,0,0,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource PanelFg}"
                        Opacity="0.6" Cursor="Hand"
                        FontSize="11" Padding="0"/>
            </Grid>

            <!-- 항목 목록 -->
            <ScrollViewer Grid.Row="1"
                          MaxHeight="140"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ClipboardItem}">
                            <Button Command="{Binding DataContext.PasteItemCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding FullText}"
                                    HorizontalContentAlignment="Left"
                                    BorderThickness="0"
                                    Padding="6,4"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PanelFg}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource KeyBgHover}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="{Binding Preview}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource PanelFg}"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
