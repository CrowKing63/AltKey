<Window x:Class="AltKey.Views.FocusA11ySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AltKey.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="포커스 가시화 상세 설정"
        Width="560" Height="440"
        MinWidth="500" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E"
        d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <Border Background="{DynamicResource SettingsBg}"
            CornerRadius="12"
            Padding="20">
        <StackPanel>
            <TextBlock Text="포커스 가시화 상세 설정"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SettingsFg}"
                       Margin="0,0,0,6"/>
            <TextBlock Text="탭 탐색 동작과 포커스 공지 정책을 설정합니다."
                       FontSize="11"
                       Foreground="{DynamicResource SettingsFgSub}"
                       Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="{DynamicResource SettingsFgSub}"
                       Margin="0,0,0,4"
                       Text="탭 키로 키보드 키를 탐색할 수 있으며, Narrator나 외부 보조기기 사용 시 유용합니다."/>
            <TextBlock TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="{DynamicResource SettingsFgSub}"
                       Margin="0,0,0,16"
                       Text="물리 키보드/외부 스위치의 Tab, Shift+Tab, Enter, Space 입력으로 동작합니다."/>

            <TextBlock Text="탭 탐색 범위" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding KeyboardA11yNavigationScopes}"
                      SelectedItem="{Binding KeyboardA11yNavigationScope}"
                      Margin="0,0,0,8"/>

            <TextBlock Text="탭 탐색 종료 키 (VK_이름)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
            <TextBox Text="{Binding KeyboardA11yExitKey, UpdateSourceTrigger=PropertyChanged}"
                     Height="26" Margin="0,0,0,12"/>

            <TextBlock Text="LiveRegion 공지" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
            <CheckBox Content="탭 이동 시 현재 포커스 공지"
                      Foreground="{DynamicResource SettingsFg}"
                      IsChecked="{Binding KeyboardA11yAnnounceFocus}"
                      Margin="0,0,0,16"/>

            <Button Content="닫기"
                    Height="30"
                    HorizontalAlignment="Right"
                    Width="96"
                    Click="CloseButton_Click"
                    Background="{DynamicResource SettingsHighlight}"
                    Foreground="{DynamicResource SettingsFg}"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Border>
</Window>
