<Window x:Class="AltKey.Views.FocusA11ySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AltKey.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="포커스 가시화 상세 설정"
        Width="560" Height="460"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="Manual"
        Background="{DynamicResource SettingsBg}"
        d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <Window.Resources>
        <!-- 접근성: 이 창에서만 Fluent 스타일을 적용해 포커스와 탐색 흐름을 시각적으로 일관되게 유지한다. -->
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}"/>
    </Window.Resources>

    <Border Background="{DynamicResource SettingsBg}"
            CornerRadius="12"
            Padding="20">
        <StackPanel>
            <Border Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="포커스 가시화 상세 설정"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SettingsFg}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="키보드 탐색 동작과 포커스 공지를 조정합니다."
                               FontSize="11"
                               Foreground="{DynamicResource SettingsFgSub}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{DynamicResource SettingsFgSub}"
                               Margin="0,0,0,4"
                               Text="키보드로 화면 요소를 탐색하고 현재 위치를 안내하는 보조기능 설정입니다."/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{DynamicResource SettingsFgSub}"
                               Margin="0,0,0,12"
                               Text="Tab, Shift+Tab, Enter, Space 입력으로 동작합니다."/>

                    <TextBlock Text="탐색 범위" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding KeyboardA11yNavigationScopes}"
                              SelectedItem="{Binding KeyboardA11yNavigationScope}"
                              Margin="0,0,0,8"/>

                    <TextBlock Text="탐색 종료 키 (VK_이름)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding KeyboardA11yExitKey, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="LiveRegion 공지" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                    <CheckBox Content="포커스 이동 시 현재 포커스 공지"
                              Foreground="{DynamicResource SettingsFg}"
                              IsChecked="{Binding KeyboardA11yAnnounceFocus}"/>
                </StackPanel>
            </Border>

            <Button Content="닫기"
                    Height="34"
                    HorizontalAlignment="Right"
                    Width="110"
                    Click="CloseButton_Click"
                    Background="{DynamicResource SettingsHighlight}"
                    Foreground="{DynamicResource SettingsFg}"
                    BorderThickness="0"
                    Cursor="Hand"
                    AutomationProperties.Name="포커스 가시화 상세 설정 닫기"/>
        </StackPanel>
    </Border>
</Window>
