<UserControl x:Class="AltKey.Views.SuggestionBar"
             x:Name="SuggestionRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:AltKey.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SuggestionBarViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 접근성: 추천 바도 키보드 카드와 같은 라운드 칩 구조로 맞춰 현재 조합과 추천 후보를 빠르게 구분합니다. -->
        <Style x:Key="SuggestionTextButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="{DynamicResource ScaledKeyFontSize}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="MinWidth" Value="64"/>
            <Setter Property="Height"
                    Value="{Binding DataContext.Keyboard.SuggestionChipHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource SuggestionChipBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource PanelFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SuggestionChipBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChipBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background"
                                        Value="{DynamicResource SuggestionChipHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChipBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ChipBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsScanFocused}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- 접근성: 추천 바 판 자체보다 각 후보 칩을 우선 인식하도록 배경 판은 투명하게 유지합니다. -->
    <Border Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Padding="2,2"
            ClipToBounds="True">
        <StackPanel Orientation="Horizontal">

                <!-- 첫 번째 슬롯: 현재 조합 중인 단어 -->
                <Button Content="{Binding CurrentWord}"
                        Visibility="{Binding HasCurrentWord, Converter={StaticResource BoolToVis}}"
                        Command="{Binding CommitCurrentWordCommand}"
                        Background="{DynamicResource SuggestionCurrentBg}"
                        Foreground="{DynamicResource SuggestionCurrentFg}"
                        BorderBrush="{DynamicResource SuggestionCurrentBorder}"
                        FontWeight="SemiBold"
                        ToolTip="좌클릭 입력 · 우클릭 취소"
                        ContextMenu="{x:Null}"
                        PreviewMouseRightButtonUp="CurrentWordSlot_RightClick">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SuggestionTextButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentWordScanFocused}" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.InputBindings>
                        <MouseBinding MouseAction="RightClick" Command="{Binding CancelCurrentWordCommand}"/>
                    </Button.InputBindings>
                </Button>

                <!-- 현재 조합 슬롯과 추천 후보 사이를 느슨하게 분리해 오탭을 줄입니다. -->
                <Separator Visibility="{Binding HasCurrentWord, Converter={StaticResource BoolToVis}}"
                           Margin="4,4"
                           Opacity="0.45"/>

                <!-- 추천 후보 목록 -->
                <ItemsControl ItemsSource="{Binding SuggestionScanTargets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding DisplayText}"
                                    Command="{Binding DataContext.AcceptSuggestionCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding DisplayText}"
                                    Background="{DynamicResource SuggestionChipBg}"
                                    Foreground="{DynamicResource PanelFg}"
                                    ToolTip="좌클릭 입력 · 우클릭 관리">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SuggestionTextButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=IsScanFocused}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="사용자 사전에서 제거"
                                                  Command="{Binding DataContext.RemoveSuggestionCommand,
                                                      Source={x:Reference SuggestionRoot}}"
                                                  CommandParameter="{Binding DisplayText}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

        </StackPanel>
    </Border>
</UserControl>
