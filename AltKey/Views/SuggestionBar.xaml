<UserControl x:Class="AltKey.Views.SuggestionBar"
             x:Name="SuggestionRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:AltKey.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SuggestionBarViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="SuggestionTextButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="{DynamicResource ScaledKeyFontSize}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsScanFocused}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border Background="{DynamicResource PanelBg}" Padding="4,2" ClipToBounds="True">
        <StackPanel Orientation="Horizontal">

            <!-- 첫 번째 슬롯: 현재 조합 중인 단어 -->
            <Button Content="{Binding CurrentWord}"
                    Visibility="{Binding HasCurrentWord, Converter={StaticResource BoolToVis}}"
                    Command="{Binding CommitCurrentWordCommand}"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource PanelFg}"
                    FontWeight="SemiBold"
                    ToolTip="좌클릭: 저장 · 우클릭: 취소"
                    ContextMenu="{x:Null}"
                    PreviewMouseRightButtonUp="CurrentWordSlot_RightClick">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SuggestionTextButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentWordScanFocused}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.InputBindings>
                    <MouseBinding MouseAction="RightClick" Command="{Binding CancelCurrentWordCommand}"/>
                </Button.InputBindings>
            </Button>

            <!-- 구분선 -->
            <Separator Visibility="{Binding HasCurrentWord, Converter={StaticResource BoolToVis}}"
                       Margin="2,2"/>

            <!-- 기존 제안 목록 -->
            <ItemsControl ItemsSource="{Binding SuggestionScanTargets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding DisplayText}"
                                Command="{Binding DataContext.AcceptSuggestionCommand,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding DisplayText}"
                                Background="Transparent"
                                Foreground="{DynamicResource PanelFg}"
                                ToolTip="좌클릭: 입력 · 우클릭: 관리">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SuggestionTextButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=IsScanFocused}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="사용자 사전에서 제거"
                                              Command="{Binding DataContext.RemoveSuggestionCommand,
                                                  Source={x:Reference SuggestionRoot}}"
                                              CommandParameter="{Binding DisplayText}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</UserControl>
