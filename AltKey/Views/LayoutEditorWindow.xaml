<Window x:Class="AltKey.Views.LayoutEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:AltKey.ViewModels"
        xmlns:views="clr-namespace:AltKey.Views"
        xmlns:conv="clr-namespace:AltKey.Themes"
        mc:Ignorable="d"
        Title="레이아웃 편집기"
        Width="920" Height="620"
        MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E"
        d:DataContext="{d:DesignInstance vm:LayoutEditorViewModel}">
    <Window.Resources>
        <BooleanToVisibilityConverter     x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:WidthToPixelConverter       x:Key="WidthToPx"/>

        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background"      Value="#33FFFFFF"/>
            <Setter Property="Foreground"      Value="#EEFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background"      Value="#3B82F6"/>
            <Setter Property="Foreground"      Value="#FFFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"  Value="#33FFFFFF"/>
            <Setter Property="Foreground"  Value="#EEFFFFFF"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="Padding"     Value="6,4"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 상단 툴바 ── -->
        <Border Grid.Row="0" Background="#FF12121F" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 레이아웃 선택 + 불러오기 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="레이아웃:" Foreground="#AAFFFFFF"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding AvailableLayouts}"
                              SelectedItem="{Binding SelectedLayoutToLoad}"
                              Width="160" Height="26" Margin="0,0,4,0"/>
                    <Button Content="불러오기"
                            Command="{Binding LoadSelectedCommand}"
                            Style="{StaticResource DarkBtn}"/>
                </StackPanel>

                <!-- 레이아웃 이름 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="표시 이름:" Foreground="#AAFFFFFF"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding LayoutName, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" Height="26"
                             Background="#33FFFFFF" Foreground="#EEFFFFFF"
                             BorderBrush="#55FFFFFF" Padding="6,2"/>
                </StackPanel>

                <!-- 저장 버튼 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="저장"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource AccentBtn}"/>
                    <Button x:Name="SaveAsButton"
                            Content="다른 이름으로 저장"
                            Click="SaveAsButton_Click"
                            Style="{StaticResource DarkBtn}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 본문 ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: 키 편집 영역 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF181826" Padding="8,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="키 배치" Foreground="#AAFFFFFF"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="+ 행 추가"
                                Command="{Binding AddRowCommand}"
                                Style="{StaticResource DarkBtn}"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Padding="8">
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:EditableKeyRowVm}">
                                <Border Margin="0,0,0,8" Background="#22FFFFFF"
                                        CornerRadius="4" Padding="6,4">
                                    <StackPanel>
                                        <!-- 행 헤더 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Button Content="+ 키"
                                                    Command="{Binding DataContext.AddKeyToRowCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DarkBtn}" FontSize="10"/>
                                            <Button Content="행 삭제"
                                                    Command="{Binding DataContext.RemoveRowCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#55FF4444" Foreground="#FFEEAAAA"
                                                    BorderThickness="0" Padding="6,3"
                                                    Margin="4,0" FontSize="10" Cursor="Hand"/>
                                        </StackPanel>

                                        <!-- 키 버튼 목록 -->
                                        <ItemsControl ItemsSource="{Binding Keys}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:EditableKeySlotVm}">
                                                    <Border Margin="2" MinWidth="36" MinHeight="34"
                                                            Width="{Binding EditWidth, Converter={StaticResource WidthToPx}}"
                                                            CornerRadius="4" BorderThickness="1.5" Cursor="Hand">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background"   Value="#FF2D2D3F"/>
                                                                <Setter Property="BorderBrush"  Value="#44FFFFFF"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background"  Value="#FF1E3A5F"/>
                                                                        <Setter Property="BorderBrush" Value="#FF3B82F6"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                Command="{Binding DataContext.SelectKeyCommand,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Grid>
                                                            <TextBlock Text="{Binding EditLabel}"
                                                                       Foreground="#EEFFFFFF"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="2"/>
                                                            <Button Content="×"
                                                                    Width="14" Height="14"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="0,1,1,0" FontSize="9"
                                                                    Background="Transparent"
                                                                    Foreground="#88FFFFFF"
                                                                    BorderThickness="0" Cursor="Hand"
                                                                    Command="{Binding DataContext.RemoveKeyCommand,
                                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- 우측: 속성 패널 -->
            <Border Grid.Column="1" Background="#FF181826"
                    BorderBrush="#33FFFFFF" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                    <StackPanel>

                        <!-- 안내 (키 미선택 시) -->
                        <TextBlock Text="왼쪽 키를 클릭해&#10;속성을 편집하세요"
                                   Foreground="#66FFFFFF" FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasSelectedKey,
                                       Converter={StaticResource InvBoolToVis}}"/>

                        <!-- 선택된 키 편집 -->
                        <StackPanel Visibility="{Binding HasSelectedKey,
                                        Converter={StaticResource BoolToVis}}">

                            <TextBlock Text="라벨" Style="{StaticResource LabelText}"/>
                            <TextBox Text="{Binding SelectedKey.EditLabel,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}"/>

                            <TextBlock Text="Shift 라벨 (선택)" Style="{StaticResource LabelText}"/>
                            <TextBox Text="{Binding SelectedKey.EditShiftLabel,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}"/>

                            <TextBlock Style="{StaticResource LabelText}">
                                <Run Text="너비: "/>
                                <Run Text="{Binding SelectedKey.EditWidth, StringFormat=F1}"/>
                            </TextBlock>
                            <Slider Minimum="0.5" Maximum="6.0" TickFrequency="0.5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding SelectedKey.EditWidth}"
                                    Margin="0,0,0,8"/>

                            <TextBlock Style="{StaticResource LabelText}">
                                <Run Text="앞 여백: "/>
                                <Run Text="{Binding SelectedKey.EditGapBefore, StringFormat=F1}"/>
                            </TextBlock>
                            <Slider Minimum="0.0" Maximum="4.0" TickFrequency="0.5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding SelectedKey.EditGapBefore}"
                                    Margin="0,0,0,12"/>

                            <Separator Background="#33FFFFFF" Margin="0,0,0,10"/>

                            <TextBlock Text="액션" Foreground="#EEFFFFFF"
                                       FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <views:ActionBuilderView DataContext="{Binding ActionBuilder}"/>

                            <Button Content="액션 적용"
                                    Command="{Binding ApplyActionCommand}"
                                    Style="{StaticResource AccentBtn}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── 하단 상태바 ── -->
        <Border Grid.Row="2" Background="#FF12121F" Padding="12,5">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#88FFFFFF" FontSize="11"/>
        </Border>
    </Grid>
</Window>
