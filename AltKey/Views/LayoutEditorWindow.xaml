<Window x:Class="AltKey.Views.LayoutEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:AltKey.ViewModels"
        xmlns:views="clr-namespace:AltKey.Views"
        xmlns:conv="clr-namespace:AltKey.Themes"
        xmlns:ctrl="clr-namespace:AltKey.Controls"
        mc:Ignorable="d"
        Title="레이아웃 편집기"
        Width="1200" Height="750"
        MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E"
        d:DataContext="{d:DesignInstance vm:LayoutEditorViewModel}">
    <Window.Resources>
        <BooleanToVisibilityConverter     x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:WidthToPixelConverter       x:Key="WidthToPx"/>
        <conv:NullToCollapsedConverter    x:Key="NullToCollapsed"/>

        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background"      Value="#33FFFFFF"/>
            <Setter Property="Foreground"      Value="#EEFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background"      Value="#3B82F6"/>
            <Setter Property="Foreground"      Value="#FFFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background"      Value="#55FF4444"/>
            <Setter Property="Foreground"      Value="#FFEEAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"  Value="#33FFFFFF"/>
            <Setter Property="Foreground"  Value="#EEFFFFFF"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="Padding"     Value="6,4"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 상단 툴바 ── -->
        <Border Grid.Row="0" Background="#FF12121F" Padding="12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1행: 레이아웃 선택 + 불러오기 / 새 레이아웃 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,0,6">
                    <TextBlock Text="레이아웃:" Foreground="#AAFFFFFF"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding AvailableLayouts}"
                              SelectedItem="{Binding SelectedLayoutToLoad}"
                              Width="160" Height="26" Margin="0,0,4,0"/>
                    <Button Content="불러오기"
                            Command="{Binding LoadSelectedCommand}"
                            Style="{StaticResource DarkBtn}"/>
                    <Button Content="새 레이아웃"
                            Command="{Binding NewLayoutCommand}"
                            Style="{StaticResource DarkBtn}"
                            Margin="12,0,0,0"/>
                </StackPanel>

                <!-- 2행: 파일명 + 표시이름 + 저장/다른이름저장/삭제 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,16,0">
                        <TextBlock Text="파일명:" Foreground="#AAFFFFFF"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding CurrentFileName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="160" Height="26"
                                 Background="#33FFFFFF" Foreground="#EEFFFFFF"
                                 BorderBrush="#55FFFFFF" Padding="6,2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="표시 이름:" Foreground="#AAFFFFFF"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding LayoutName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Height="26"
                                 Background="#33FFFFFF" Foreground="#EEFFFFFF"
                                 BorderBrush="#55FFFFFF" Padding="6,2"/>
                    </StackPanel>

                    <!-- 저장 버튼들 -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="저장"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource AccentBtn}"/>
                        <Button Content="다른 이름으로 저장"
                                Command="{Binding SaveAsCommand}"
                                Style="{StaticResource DarkBtn}"
                                Visibility="{Binding IsExistingLayout,
                                    Converter={StaticResource BoolToVis}}"/>
                        <Button Content="삭제"
                                Command="{Binding RequestDeleteLayoutCommand}"
                                Style="{StaticResource DangerBtn}"
                                Visibility="{Binding CanDeleteLayout,
                                    Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ── 본문 ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: 키 편집 영역 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF181826" Padding="8,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="키 배치" Foreground="#AAFFFFFF"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="+ 열 추가"
                                Command="{Binding AddColumnCommand}"
                                Style="{StaticResource DarkBtn}"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Padding="8">
                    <ItemsControl ItemsSource="{Binding Columns}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:EditableKeyColumnVm}">
                                <Border Margin="0,0,4,0" Background="#22FFFFFF"
                                        CornerRadius="4" Padding="6,4">
                                    <StackPanel>
                                        <!-- 열 헤더 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="열" Foreground="#AAFFFFFF"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="간격:" Foreground="#88FFFFFF" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ctrl:NumericAdjuster
                                                Value="{Binding Gap}"
                                                Minimum="0.0" Maximum="3.0" Step="0.1" DecimalPlaces="1"
                                                ButtonBackground="#33FFFFFF"
                                                ButtonForeground="#EEFFFFFF"
                                                TextBoxBackground="#33FFFFFF"
                                                TextBoxForeground="#EEFFFFFF"
                                                TextBoxBorderBrush="#55FFFFFF"
                                                Width="110" Height="22"/>
                                            <Button Content="행 추가"
                                                    Command="{Binding DataContext.AddRowCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DarkBtn}" FontSize="10"
                                                    Margin="6,0,0,0"/>
                                            <Button Content="열 삭제"
                                                    Command="{Binding DataContext.RequestRemoveColumnCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#55FF4444" Foreground="#FFEEAAAA"
                                                    BorderThickness="0" Padding="6,3"
                                                    Margin="4,0" FontSize="10" Cursor="Hand"/>
                                        </StackPanel>

                                        <!-- 행 목록 -->
                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:EditableKeyRowVm}">
                                                    <Border Margin="0,0,0,4" Background="#18FFFFFF"
                                                            CornerRadius="3" Padding="4,3">
                                                        <StackPanel>
                                                            <!-- 행 헤더 -->
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                                <Button Content="+ 키"
                                                                        Command="{Binding DataContext.AddKeyToRowCommand,
                                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource DarkBtn}" FontSize="9"/>
                                                                <Button Content="행 삭제"
                                                                        Command="{Binding DataContext.RemoveRowCommand,
                                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="#55FF4444" Foreground="#FFEEAAAA"
                                                                        BorderThickness="0" Padding="4,2"
                                                                        Margin="2,0" FontSize="9" Cursor="Hand"/>
                                                            </StackPanel>

                                                            <!-- 키 버튼 목록 -->
                                                            <ItemsControl ItemsSource="{Binding Keys}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel Orientation="Horizontal"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type vm:EditableKeySlotVm}">
                                                                        <Border Margin="1" MinWidth="30" MinHeight="50" Height="50"
                                                                                Width="{Binding EditWidth, Converter={StaticResource WidthToPx}}"
                                                                                CornerRadius="3" BorderThickness="1" Cursor="Hand">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background"   Value="#FF2D2D3F"/>
                                                                                    <Setter Property="BorderBrush"  Value="#44FFFFFF"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                            <Setter Property="Background"  Value="#FF1E3A5F"/>
                                                                                            <Setter Property="BorderBrush" Value="#FF3B82F6"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <Border.InputBindings>
                                                                                <MouseBinding MouseAction="LeftClick"
                                                                                    Command="{Binding DataContext.SelectKeyCommand,
                                                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                    CommandParameter="{Binding}"/>
                                                                            </Border.InputBindings>
                                                                            <Grid>
                                                                                <StackPanel HorizontalAlignment="Center"
                                                                                            VerticalAlignment="Center">
                                                                                    <TextBlock Text="{Binding EditLabel}"
                                                                                               Foreground="#EEFFFFFF"
                                                                                               FontSize="12"
                                                                                               HorizontalAlignment="Center"
                                                                                               TextTrimming="CharacterEllipsis"
                                                                                               Margin="1,0"/>
                                                                                    <!-- 서브라벨 (영어/한글) -->
                                                                                    <TextBlock Text="{Binding EnglishLabel}"
                                                                                               Foreground="#66FFFFFF"
                                                                                               FontSize="8"
                                                                                               HorizontalAlignment="Center"
                                                                                               Margin="0,-1,0,0"
                                                                                               Visibility="{Binding EnglishLabel,
                                                                                                   Converter={StaticResource NullToCollapsed},
                                                                                                   FallbackValue=Collapsed}"/>
                                                                                </StackPanel>
                                                                                <Button Content="×"
                                                                                        Width="12" Height="12"
                                                                                        HorizontalAlignment="Right"
                                                                                        VerticalAlignment="Top"
                                                                                        Margin="0,0,0,0" FontSize="8"
                                                                                        Background="Transparent"
                                                                                        Foreground="#88FFFFFF"
                                                                                        BorderThickness="0" Cursor="Hand"
                                                                                        Command="{Binding DataContext.RemoveKeyCommand,
                                                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                        CommandParameter="{Binding}"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- 우측: 속성 패널 -->
            <Border Grid.Column="1" Background="#FF181826"
                    BorderBrush="#33FFFFFF" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                    <StackPanel>

                        <!-- 안내 (키 미선택 시) -->
                        <TextBlock Text="왼쪽 키를 클릭해&#10;속성을 편집하세요"
                                   Foreground="#66FFFFFF" FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasSelectedKey,
                                       Converter={StaticResource InvBoolToVis}}"/>

                        <!-- 선택된 키 편집 -->
                        <StackPanel Visibility="{Binding HasSelectedKey,
                                        Converter={StaticResource BoolToVis}}">

                            <TextBlock Text="키 위치" Style="{StaticResource LabelText}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="◀ 왼쪽으로"
                                        Command="{Binding MoveKeyLeftCommand}"
                                        Style="{StaticResource DarkBtn}" FontSize="10"
                                        IsEnabled="{Binding CanMoveKeyLeft}"/>
                                <Button Content="오른쪽으로 ▶"
                                        Command="{Binding MoveKeyRightCommand}"
                                        Style="{StaticResource DarkBtn}" FontSize="10"
                                        IsEnabled="{Binding CanMoveKeyRight}"/>
                            </StackPanel>

                            <TextBlock Text="라벨" Style="{StaticResource LabelText}"/>
                            <TextBox Text="{Binding SelectedKey.EditLabel,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}"/>

                            <TextBlock Text="Shift 라벨 (선택)" Style="{StaticResource LabelText}"/>
                            <TextBox Text="{Binding SelectedKey.EditShiftLabel,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}"/>

                            <TextBlock Text="영어 라벨" Style="{StaticResource LabelText}"/>
                            <TextBox Text="{Binding SelectedKey.EnglishLabel,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}"/>

                            <TextBlock Text="영어 Shift 라벨" Style="{StaticResource LabelText}"/>
                            <TextBox Text="{Binding SelectedKey.EnglishShiftLabel,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}"/>

                            <TextBlock Text="너비" Style="{StaticResource LabelText}"/>
                            <ctrl:NumericAdjuster Value="{Binding SelectedKey.EditWidth}"
                                                  Minimum="0.5" Maximum="6.0" Step="0.1" DecimalPlaces="1"
                                                  ButtonBackground="#33FFFFFF"
                                                  ButtonForeground="#EEFFFFFF"
                                                  TextBoxBackground="#33FFFFFF"
                                                  TextBoxForeground="#EEFFFFFF"
                                                  TextBoxBorderBrush="#55FFFFFF"
                                                  Margin="0,0,0,8"/>

                            <TextBlock Text="앞 여백" Style="{StaticResource LabelText}"/>
                            <ctrl:NumericAdjuster Value="{Binding SelectedKey.EditGapBefore}"
                                                  Minimum="0.0" Maximum="4.0" Step="0.1" DecimalPlaces="1"
                                                  ButtonBackground="#33FFFFFF"
                                                  ButtonForeground="#EEFFFFFF"
                                                  TextBoxBackground="#33FFFFFF"
                                                  TextBoxForeground="#EEFFFFFF"
                                                  TextBoxBorderBrush="#55FFFFFF"
                                                  Margin="0,0,0,12"/>

                            <Separator Background="#33FFFFFF" Margin="0,0,0,10"/>

                            <TextBlock Text="액션" Foreground="#EEFFFFFF"
                                       FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <views:ActionBuilderView DataContext="{Binding ActionBuilder}"/>

                            <Button Content="액션 적용"
                                    Command="{Binding ApplyActionCommand}"
                                    Style="{StaticResource AccentBtn}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0"/>

                            <Button Content="라벨 자동 채우기 (VK 기반)"
                                    Command="{Binding AutoFillLabelsCommand}"
                                    Style="{StaticResource DarkBtn}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,4,0,0"
                                    ToolTip="SendKey 액션의 VK 코드를 기반으로 한글/영어 라벨을 자동으로 설정합니다"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── 하단 상태바 ── -->
        <Border Grid.Row="2" Background="#FF12121F" Padding="12,5">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#88FFFFFF" FontSize="11"/>
        </Border>

        <!-- ── 열 삭제 확인 오버레이 ── -->
        <Border Grid.RowSpan="3"
                Background="#CC000000"
                Visibility="{Binding ShowColumnDeleteDialog,
                    Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="10">
            <Border Background="#FF2D2D3F" CornerRadius="8"
                    Padding="24,20" MaxWidth="400" MaxHeight="200"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#55FFFFFF" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="열 삭제 확인" Foreground="#EEFFFFFF"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <TextBlock Text="이 열에 행과 버튼이 있습니다. 어떻게 처리할까요?"
                               Foreground="#AAFFFFFF" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="취소"
                                Command="{Binding CancelDeleteColumnCommand}"
                                Style="{StaticResource DarkBtn}" Margin="0,0,6,0"/>
                        <Button Content="앞 열로 이동"
                                Command="{Binding ConfirmDeleteColumnMoveCommand}"
                                Style="{StaticResource AccentBtn}" Margin="0,0,6,0"
                                Visibility="{Binding CanMoveColumnContents,
                                    Converter={StaticResource BoolToVis}}"/>
                        <Button Content="통째로 삭제"
                                Command="{Binding ConfirmDeleteColumnAllCommand}"
                                Style="{StaticResource DangerBtn}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ── 레이아웃 삭제 확인 오버레이 ── -->
        <Border Grid.RowSpan="3"
                Background="#CC000000"
                Visibility="{Binding ShowDeleteLayoutDialog,
                    Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="11">
            <Border Background="#FF2D2D3F" CornerRadius="8"
                    Padding="24,20" MaxWidth="350" MaxHeight="150"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#55FFFFFF" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="레이아웃 삭제 확인" Foreground="#EEFFFFFF"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <TextBlock Text="정말로 이 레이아웃을 삭제하시겠습니까?"
                               Foreground="#AAFFFFFF" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="취소"
                                Command="{Binding CancelDeleteLayoutCommand}"
                                Style="{StaticResource DarkBtn}" Margin="0,0,6,0"/>
                        <Button Content="삭제"
                                Command="{Binding ConfirmDeleteLayoutCommand}"
                                Style="{StaticResource DangerBtn}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
