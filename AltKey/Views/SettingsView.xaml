<UserControl x:Class="AltKey.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AltKey.ViewModels"
             xmlns:conv="clr-namespace:AltKey.Themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border Background="#EE141420"
            CornerRadius="12"
            Padding="24,20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="설정"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="#EEFFFFFF"/>
                <Button HorizontalAlignment="Right"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#AAFFFFFF" FontSize="16" Cursor="Hand"
                        Click="CloseButton_Click"
                        ToolTip="닫기 (Esc)">
                    <TextBlock Text="✕"/>
                </Button>
            </Grid>

            <!-- 설정 항목 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- ── 테마 ─────────────────────────────────────────────── -->
                    <TextBlock Text="테마" Foreground="#AAFFFFFF" FontSize="11" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton Content="시스템 따라" Foreground="#EEFFFFFF"
                                     IsChecked="{Binding ThemeIsSystem}" Margin="0,0,12,0"/>
                        <RadioButton Content="라이트"     Foreground="#EEFFFFFF"
                                     IsChecked="{Binding ThemeIsLight}"  Margin="0,0,12,0"/>
                        <RadioButton Content="다크"       Foreground="#EEFFFFFF"
                                     IsChecked="{Binding ThemeIsDark}"/>
                    </StackPanel>

                    <!-- ── 항상 위 ─────────────────────────────────────────── -->
                    <CheckBox Content="항상 위에 표시"
                              Foreground="#EEFFFFFF"
                              IsChecked="{Binding AlwaysOnTop}"
                              Margin="0,0,0,16"/>

                    <!-- ── 유휴 투명도 ─────────────────────────────────────── -->
                    <TextBlock Foreground="#AAFFFFFF" FontSize="11" Margin="0,0,0,4">
                        <Run Text="유휴 투명도: "/>
                        <Run Text="{Binding OpacityIdle, StringFormat=P0}"/>
                    </TextBlock>
                    <Slider Minimum="0.1" Maximum="1.0" TickFrequency="0.05"
                            IsSnapToTickEnabled="True"
                            Value="{Binding OpacityIdle}"
                            Foreground="{StaticResource KeyFgSticky}"
                            Margin="0,0,0,16"/>

                    <!-- ── 페이딩 딜레이 ───────────────────────────────────── -->
                    <TextBlock Foreground="#AAFFFFFF" FontSize="11" Margin="0,0,0,4">
                        <Run Text="페이딩 딜레이: "/>
                        <Run Text="{Binding FadeDelaySec, StringFormat={}{0}초}"/>
                    </TextBlock>
                    <Slider Minimum="1" Maximum="30" TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding FadeDelaySec}"
                            Foreground="{StaticResource KeyFgSticky}"
                            Margin="0,0,0,16"/>

                    <!-- ── 체류 클릭 ───────────────────────────────────────── -->
                    <CheckBox Content="체류 클릭 (Dwell Click)"
                              Foreground="#EEFFFFFF"
                              IsChecked="{Binding DwellEnabled}"
                              Margin="0,0,0,8"/>
                    <TextBlock Foreground="#AAFFFFFF" FontSize="11" Margin="16,0,0,4">
                        <Run Text="체류 시간: "/>
                        <Run Text="{Binding DwellTimeMs, StringFormat={}{0}ms}"/>
                    </TextBlock>
                    <Slider Minimum="200" Maximum="3000" TickFrequency="100"
                            IsSnapToTickEnabled="True"
                            Value="{Binding DwellTimeMs}"
                            IsEnabled="{Binding DwellEnabled}"
                            Foreground="{StaticResource KeyFgSticky}"
                            Margin="16,0,0,16"/>

                    <!-- ── 레이아웃 ─────────────────────────────────────────── -->
                    <TextBlock Text="기본 레이아웃" Foreground="#AAFFFFFF" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableLayouts}"
                              SelectedItem="{Binding SelectedLayout}"
                              Height="28" Margin="0,0,0,16"/>

                    <!-- ── 전역 단축키 ─────────────────────────────────────── -->
                    <TextBlock Text="전역 단축키" Foreground="#AAFFFFFF" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding GlobalHotkey, UpdateSourceTrigger=LostFocus}"
                             Height="28" Margin="0,0,0,16"
                             Background="#33FFFFFF" Foreground="#EEFFFFFF"
                             BorderBrush="#55FFFFFF" Padding="6,4"/>

                    <!-- ── T-8.1: 자동 실행 ───────────────────────────────── -->
                    <CheckBox Content="Windows 시작 시 자동 실행"
                              Foreground="#EEFFFFFF"
                              IsChecked="{Binding RunOnStartup}"
                              Margin="0,0,0,16"/>

                    <!-- ── T-8.2: 키 클릭 사운드 ─────────────────────────── -->
                    <CheckBox Content="키 클릭 사운드"
                              Foreground="#EEFFFFFF"
                              IsChecked="{Binding SoundEnabled}"
                              Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal"
                                Margin="16,0,0,16"
                                Visibility="{Binding SoundEnabled, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="사운드 파일:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   Foreground="#AAFFFFFF"/>
                        <TextBlock VerticalAlignment="Center" Opacity="0.7"
                                   MaxWidth="140" Foreground="#EEFFFFFF"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding SoundFilePath}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SoundFilePath}" Value="">
                                            <Setter Property="Text" Value="기본 사운드 파일"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Content="찾아보기"
                                Command="{Binding BrowseSoundFileCommand}"
                                Margin="6,0,0,0"
                                Padding="6,2"
                                Background="#33FFFFFF"
                                Foreground="#EEFFFFFF"
                                BorderThickness="0"
                                Cursor="Hand"/>
                        <Button Content="초기화"
                                Command="{Binding ResetSoundFileCommand}"
                                Margin="4,0,0,0"
                                Padding="6,2"
                                Background="#33FFFFFF"
                                Foreground="#EEFFFFFF"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>

                    <!-- ── T-8.4: 클립보드 패널 ──────────────────────────── -->
                    <CheckBox Content="클립보드 히스토리 패널"
                              Foreground="#EEFFFFFF"
                              IsChecked="{Binding ClipboardPanelEnabled}"
                              Margin="0,0,0,16"/>

                    <Separator Background="#33FFFFFF" Margin="0,0,0,16"/>

                    <!-- ── T-8.5: 앱별 레이아웃 ──────────────────────────── -->
                    <TextBlock Text="앱별 레이아웃"
                               Foreground="#AAFFFFFF"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Profiles}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#33FFFFFF"
                                             Foreground="#EEFFFFFF"
                                             BorderBrush="#55FFFFFF"
                                             Padding="4,2"
                                             Grid.Column="0"
                                             Margin="0,0,4,0">
                                        <TextBox.Resources>
                                            <VisualBrush x:Key="Hint" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="예: code.exe" Foreground="#66FFFFFF" Margin="6,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </TextBox.Resources>
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background" Value="{StaticResource Hint}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBlock Text="→"
                                               Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"
                                               Foreground="#AAFFFFFF"/>
                                    <TextBox Text="{Binding LayoutName, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#33FFFFFF"
                                             Foreground="#EEFFFFFF"
                                             BorderBrush="#55FFFFFF"
                                             Padding="4,2"
                                             Grid.Column="2"
                                             Margin="0,0,4,0"/>
                                    <Button Content="✕"
                                            Grid.Column="3"
                                            Command="{Binding DataContext.RemoveProfileCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            Foreground="#FF6B6B"
                                            BorderThickness="0"
                                            Cursor="Hand"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ 추가"
                            Command="{Binding AddProfileCommand}"
                            Margin="0,0,0,4"
                            Padding="8,4"
                            Background="#33FFFFFF"
                            Foreground="#EEFFFFFF"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="저장"
                            Command="{Binding SaveProfilesCommand}"
                            Margin="4,4,0,16"
                            Padding="8,4"
                            Background="#3B82F6"
                            Foreground="#EEFFFFFF"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <Separator Background="#33FFFFFF" Margin="0,0,0,16"/>

                    <!-- ── T-5.12: 관리자 권한으로 재시작 ─────────────────── -->
                    <Border Background="#33FFA500" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#FFEEAA"
                                   Text="⚠️ 관리자 앱에 입력하려면 관리자 권한으로 재시작하세요."/>
                    </Border>
                    <Button Content="관리자 권한으로 재시작"
                            Command="{Binding RestartAsAdminCommand}"
                            Height="32" Cursor="Hand"
                            Background="#553B82F6" Foreground="#EEFFFFFF"
                            BorderThickness="0"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
