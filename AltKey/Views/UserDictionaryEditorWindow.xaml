<Window x:Class="AltKey.Views.UserDictionaryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:AltKey.ViewModels"
        mc:Ignorable="d"
        Title="사용자 단어 편집기"
        Width="800" Height="600"
        MinWidth="600" MinHeight="450"
        WindowStartupLocation="Manual"
        Background="{DynamicResource SettingsBg}"
        d:DataContext="{d:DesignInstance vm:UserDictionaryEditorViewModel}">

    <Window.Resources>
        <!-- 접근성: 편집 밀도가 높은 창에서 포커스/선택 상태를 빠르게 식별할 수 있게 공용 스타일을 적용합니다. -->
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}"/>
        <Style TargetType="DataGrid" BasedOn="{StaticResource FluentDataGridStyle}"/>

        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SettingsHighlight}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SettingsFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SettingsFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource ElevatedWarningBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ElevatedWarningFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"  Value="{DynamicResource SettingsHighlight}"/>
            <Setter Property="Foreground"  Value="{DynamicResource SettingsFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
            <Setter Property="Padding"     Value="6,4"/>
            <Setter Property="CaretBrush"  Value="{DynamicResource SettingsFg}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 헤더 ── -->
        <Border Grid.Row="0" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="16,10">
            <Grid>
                <TextBlock Text="사용자 단어 편집기"
                           Foreground="{DynamicResource SettingsFg}"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right"
                        Content="✕" FontSize="14"
                        Background="Transparent" Foreground="{DynamicResource SettingsFgSub}"
                        BorderThickness="0" Cursor="Hand" Padding="8,2"
                        Click="CloseButton_Click"
                        ToolTip="닫기 (Esc)"
                        AutomationProperties.Name="닫기"/>
            </Grid>
        </Border>

        <!-- ── 탭 ── -->
        <Border Grid.Row="1" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="단어"
                             Foreground="{DynamicResource SettingsFg}"
                             IsChecked="{Binding IsWordTabSelected, Mode=TwoWay}"
                             Margin="0,0,12,0" Padding="6,3"
                             GroupName="MainTab"/>
                <RadioButton Content="바이그램"
                             Foreground="{DynamicResource SettingsFg}"
                             IsChecked="{Binding IsBigramTabSelected, Mode=TwoWay}"
                             Padding="6,3"
                             GroupName="MainTab"/>
            </StackPanel>
        </Border>

        <!-- ── 단어 탭 ── -->
        <Grid Grid.Row="2" Visibility="{Binding WordTabVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 언어 탭 -->
            <Border Grid.Row="0" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="한국어"
                                 Foreground="{DynamicResource SettingsFg}"
                                 IsChecked="{Binding IsKoreanTabActive, Mode=TwoWay}"
                                 Margin="0,0,12,0" Padding="6,3"
                                 GroupName="DictTab"/>
                    <RadioButton Content="영어"
                                 Foreground="{DynamicResource SettingsFg}"
                                 IsChecked="{Binding IsEnglishTabActive, Mode=TwoWay}"
                                 Padding="6,3"
                                 GroupName="DictTab"/>
                </StackPanel>
            </Border>

            <!-- 툴바 -->
            <Border Grid.Row="1" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 접근성: 한 줄로 유지하되 폭이 부족하면 자동 줄바꿈되어 입력 요소가 사라지지 않도록 합니다. -->
                    <WrapPanel Grid.Column="0" VerticalAlignment="Center" ItemHeight="28">
                        <TextBlock Text="검색:" Foreground="{DynamicResource SettingsFgSub}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                                 Style="{StaticResource InputBox}"
                                 Width="190" Height="26" Margin="0,0,10,0"
                                 AutomationProperties.Name="단어 검색 입력"/>
                        <TextBlock Text="추가:" Foreground="{DynamicResource SettingsFgSub}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding NewWord, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}"
                                 Width="150" Height="26" Margin="0,0,4,0"
                                 ToolTip="추가할 단어 입력"
                                 AutomationProperties.Name="추가 단어 입력"/>
                        <TextBox Text="{Binding NewWordFrequency, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}"
                                 Width="70" Height="26" Margin="0,0,4,0"
                                 ToolTip="추가 단어 빈도"
                                 AutomationProperties.Name="추가 단어 빈도 입력"/>
                        <Button Content="+ 추가"
                                Command="{Binding AddWordCommand}"
                                Style="{StaticResource AccentBtn}"
                                AutomationProperties.Name="단어 추가 버튼"/>
                    </WrapPanel>

                    <!-- 제거 버튼 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="선택 항목 제거"
                                Command="{Binding RemoveSelectedCommand}"
                                Style="{StaticResource DarkBtn}"
                                ToolTip="체크된 단어를 삭제합니다"/>
                        <Button Content="전체 삭제"
                                Command="{Binding ClearAllCommand}"
                                Style="{StaticResource DangerBtn}"
                                ToolTip="현재 탭의 모든 사용자 단어를 삭제합니다"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 목록 -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding FilteredWords}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource SettingsHighlight}"
                      Background="{DynamicResource SettingsBg}"
                      Foreground="{DynamicResource SettingsFg}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SettingsHighlight}"
                      BorderBrush="{DynamicResource SettingsHighlight}"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      FontSize="12"
                      Margin="0,0,0,8">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="✓"
                                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            Width="36"/>
                    <DataGridTextColumn Header="단어"
                                        Binding="{Binding Word}"
                                        Width="*"
                                        IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="빈도" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Frequency, UpdateSourceTrigger=LostFocus}"
                                         Background="Transparent"
                                         Foreground="{DynamicResource SettingsFg}"
                                         BorderThickness="0"
                                         HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕"
                                        Command="{Binding DataContext.RemoveOneCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        Foreground="{DynamicResource SettingsFgHint}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FontSize="11"
                                        ToolTip="이 단어 제거"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ── 바이그램 탭 ── -->
        <Grid Grid.Row="2" Visibility="{Binding BigramTabVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 언어 필터 -->
            <Border Grid.Row="0" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="한국어"
                                 Foreground="{DynamicResource SettingsFg}"
                                 IsChecked="{Binding IsKoreanTabActive, Mode=TwoWay}"
                                 Margin="0,0,12,0" Padding="6,3"
                                 GroupName="BigramDictTab"/>
                    <RadioButton Content="English"
                                 Foreground="{DynamicResource SettingsFg}"
                                 IsChecked="{Binding IsEnglishTabActive, Mode=TwoWay}"
                                 Padding="6,3"
                                 GroupName="BigramDictTab"/>
                </StackPanel>
            </Border>
            <Border Grid.Row="1" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="12,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="이전" Foreground="{DynamicResource SettingsFgSub}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding NewBigramPrev, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}"
                             Width="140" Height="26" Margin="0,0,8,0"
                             ToolTip="바이그램 이전 단어"
                             AutomationProperties.Name="바이그램 이전 단어 입력"/>
                    <TextBlock Text="다음" Foreground="{DynamicResource SettingsFgSub}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding NewBigramNext, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}"
                             Width="140" Height="26" Margin="0,0,8,0"
                             ToolTip="바이그램 다음 단어"
                             AutomationProperties.Name="바이그램 다음 단어 입력"/>
                    <TextBlock Text="빈도" Foreground="{DynamicResource SettingsFgSub}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding NewBigramCount, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}"
                             Width="70" Height="26" Margin="0,0,8,0"
                             ToolTip="바이그램 빈도"
                             AutomationProperties.Name="바이그램 빈도 입력"/>
                    <Button Content="+ 추가"
                            Command="{Binding AddBigramPairCommand}"
                            Style="{StaticResource AccentBtn}"
                            AutomationProperties.Name="바이그램 추가 버튼"/>
                </StackPanel>
            </Border>

            <!-- 바이그램 목록 -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding BigramRows}"
                      SelectedItem="{Binding SelectedBigramRow}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource SettingsHighlight}"
                      Background="{DynamicResource SettingsBg}"
                      Foreground="{DynamicResource SettingsFg}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SettingsHighlight}"
                      BorderBrush="{DynamicResource SettingsHighlight}"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      FontSize="12"
                      Margin="0,0,0,8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="이전 단어" Binding="{Binding Prev}" Width="*"/>
                    <DataGridTextColumn Header="다음 단어" Binding="{Binding Next}" Width="*"/>
                    <DataGridTextColumn Header="빈도" Binding="{Binding Count}" Width="80"/>
                    <DataGridTemplateColumn Header="" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="삭제"
                                        Command="{Binding DataContext.RemoveBigramPairCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DarkBtn}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 하단 버튼 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8">
                <Button Content="선택된 이전 단어 전체 삭제"
                        Command="{Binding RemoveBigramsByPrevCommand}"
                        CommandParameter="{Binding SelectedBigramRow}"
                        Style="{StaticResource DarkBtn}"
                        AutomationProperties.Name="선택된 이전 단어의 모든 다음 단어 삭제"/>
                <Button Content="모두 비우기"
                        Command="{Binding ClearAllBigramsCommand}"
                        Style="{StaticResource DangerBtn}"
                        AutomationProperties.Name="바이그램 데이터 전체 삭제"/>
            </StackPanel>
        </Grid>

        <!-- ── 상태바 ── -->
        <Border Grid.Row="3" Style="{StaticResource FluentCardBorderStyle}" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="{DynamicResource SettingsFgSub}" FontSize="11"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="닫기"
                        Click="CloseButton_Click"
                        Style="{StaticResource DarkBtn}"
                        AutomationProperties.Name="닫기"/>
            </Grid>
        </Border>
    </Grid>
</Window>

