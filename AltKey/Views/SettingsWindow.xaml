<Window x:Class="AltKey.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AltKey.ViewModels"
        xmlns:conv="clr-namespace:AltKey.Themes"
        xmlns:ctrl="clr-namespace:AltKey.Controls"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="설정"
        Width="694" Height="780"
        MinWidth="600" MinHeight="640"
        WindowStartupLocation="Manual"
        Background="{DynamicResource SettingsBg}"
        d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <Window.Resources>
        <ResourceDictionary>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <!-- 접근성: 설정 창 범위에서만 Fluent 컨트롤 스타일을 opt-in으로 적용해 포커스/간격 일관성을 확보한다. -->
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}"/>
        <Style TargetType="TabControl" BasedOn="{StaticResource FluentTabControlStyle}"/>
        <!-- 접근성: 수치 조절기가 모든 테마에서 동일한 입력 대비를 유지하도록 창 범위 기본값을 묶는다. -->
        <Style TargetType="{x:Type ctrl:NumericAdjuster}">
            <Setter Property="ButtonBackground" Value="{DynamicResource SettingsHighlight}"/>
            <Setter Property="ButtonForeground" Value="{DynamicResource SettingsFg}"/>
            <Setter Property="TextBoxBackground" Value="{DynamicResource SettingsBg}"/>
            <Setter Property="TextBoxForeground" Value="{DynamicResource SettingsFg}"/>
            <Setter Property="TextBoxBorderBrush" Value="{DynamicResource SettingsBorder}"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SettingsActionButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentSecondaryButtonStyle}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style x:Key="SettingsPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentPrimaryButtonStyle}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource SettingsBg}" CornerRadius="12" Padding="24,20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <Border Style="{StaticResource FluentCardBorderStyle}" Padding="12,10">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="설정" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource SettingsFg}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding CurrentVersion, StringFormat=버전 {0}}" FontSize="11" Foreground="{DynamicResource SettingsFgSub}"/>
                            <TextBlock Text=" | " FontSize="11" Foreground="{DynamicResource SettingsFgSub}" Margin="0,4"/>
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/CrowKing63/AltKey/wiki" RequestNavigate="Hyperlink_RequestNavigate">
                                    <TextBlock Text="사용자 가이드" Foreground="{DynamicResource SettingsFg}" TextDecorations="Underline"/>
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DockPanel>

            <!-- 접근성 우선: 탭 기반 정보 구조로 목적별 탐색 비용을 줄인다. -->
            <TabControl x:Name="SettingsTabControl"
                        Grid.Row="1"
                        SelectionChanged="SettingsTabControl_SelectionChanged"
                        KeyboardNavigation.TabNavigation="Continue"
                        AutomationProperties.Name="설정 카테고리 탭"
                        AutomationProperties.HelpText="외형, 상단바, 동작, 보조기능, AI 도구, 고급 설정 탭을 선택할 수 있습니다.">

                <TabItem Header="외형" AutomationProperties.Name="외형 설정 탭">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,10,8,10">
                            <TextBlock Text="테마" Style="{StaticResource SectionTitleStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <RadioButton x:Name="AppearanceFirstFocusable"
                                             Content="시스템"
                                             Foreground="{DynamicResource SettingsFg}"
                                             IsChecked="{Binding ThemeIsSystem}"
                                             Margin="0,0,12,0"
                                             KeyboardNavigation.TabIndex="10"
                                             AutomationProperties.Name="테마 시스템"/>
                                <RadioButton Content="라이트" Foreground="{DynamicResource SettingsFg}" IsChecked="{Binding ThemeIsLight}" Margin="0,0,12,0" KeyboardNavigation.TabIndex="11" AutomationProperties.Name="테마 라이트"/>
                                <RadioButton Content="다크" Foreground="{DynamicResource SettingsFg}" IsChecked="{Binding ThemeIsDark}" Margin="0,0,12,0" KeyboardNavigation.TabIndex="12" AutomationProperties.Name="테마 다크"/>
                                <RadioButton Content="고대비" Foreground="{DynamicResource SettingsFg}" IsChecked="{Binding ThemeIsHighContrast}" KeyboardNavigation.TabIndex="13" AutomationProperties.Name="테마 고대비"/>
                            </StackPanel>

                            <CheckBox Content="항상 위에 표시"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding AlwaysOnTop}"
                                      Margin="0,0,0,16"
                                      KeyboardNavigation.TabIndex="14"
                                      AutomationProperties.Name="항상 위에 표시"/>

                            <TextBlock Text="창 크기 (%)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                            <ctrl:NumericAdjuster Value="{Binding WindowScale}" Minimum="60" Maximum="200" Step="5" DecimalPlaces="0"
                                                  Margin="0,0,0,16" KeyboardNavigation.TabIndex="15" AutomationProperties.Name="창 크기 백분율"/>

                            <TextBlock Text="키 글자 크기 (%)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                            <ctrl:NumericAdjuster Value="{Binding KeyFontScalePercent}" Minimum="80" Maximum="220" Step="5" DecimalPlaces="0"
                                                  Margin="0,0,0,16" KeyboardNavigation.TabIndex="16" AutomationProperties.Name="키 글자 크기 백분율"/>

                            <TextBlock Text="유휴 투명도" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                            <ctrl:NumericAdjuster Value="{Binding OpacityIdle}" Minimum="0.1" Maximum="1.0" Step="0.05" DecimalPlaces="2"
                                                  Margin="0,0,0,16" KeyboardNavigation.TabIndex="17" AutomationProperties.Name="유휴 투명도"/>

                            <TextBlock Text="페이드 지연 (초)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                            <ctrl:NumericAdjuster Value="{Binding FadeDelaySec}" Minimum="1" Maximum="30" Step="1" DecimalPlaces="0"
                                                  Margin="0,0,0,16" KeyboardNavigation.TabIndex="18" AutomationProperties.Name="페이드 지연"/>

                            <TextBlock Text="기본 레이아웃" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding AvailableLayouts}" SelectedItem="{Binding SelectedLayout}" Height="30" Margin="0,0,0,8" KeyboardNavigation.TabIndex="19" AutomationProperties.Name="기본 레이아웃 선택"/>

                            <Button Content="레이아웃 편집기 열기"
                                    Command="{Binding OpenLayoutEditorCommand}"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Margin="0,0,0,8"
                                    KeyboardNavigation.TabIndex="20" AutomationProperties.Name="레이아웃 편집기 열기"/>

                            <Button Content="사용자 단어 편집기 열기"
                                    Command="{Binding OpenUserDictionaryEditorCommand}"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Margin="0,0,0,8"
                                    KeyboardNavigation.TabIndex="21" AutomationProperties.Name="사용자 단어 편집기 열기"
                                    ToolTip="자동완성에서 학습한 단어 목록을 확인하고 수정합니다."/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="상단바" AutomationProperties.Name="상단바 설정 탭">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,10,8,10">
                            <TextBlock Text="기본 상단바 버튼" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="기본 버튼의 표시 여부, 좌우 위치, 순서를 조정합니다." Foreground="{DynamicResource SettingsFgSub}" FontSize="11"/>
                            <TextBlock Text="접기, 최소화, 닫기 버튼은 항상 우측 끝에 고정됩니다." Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding BuiltInHeaderButtons}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding Visible}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"
                                                      Command="{Binding DataContext.SaveHeaderButtonsCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Border Grid.Column="1"
                                                    Width="36"
                                                    Height="28"
                                                    Margin="0,0,8,0"
                                                    Background="{DynamicResource SettingsHighlight}"
                                                    BorderBrush="{DynamicResource SettingsBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="6">
                                                <TextBlock Text="{Binding EffectiveIconText}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SettingsFg}"/>
                                            </Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource SettingsFg}"/>
                                                <TextBlock Text="{Binding EffectiveTooltip}" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="3"
                                                    Margin="8,0,8,0"
                                                    Padding="8,2"
                                                    MinWidth="76"
                                                    Command="{Binding DataContext.ToggleHeaderButtonPositionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    VerticalAlignment="Center">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FluentSecondaryButtonStyle}">
                                                        <Setter Property="Content" Value="◄ 우측 ►"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Position}" Value="Left">
                                                                <Setter Property="Content" Value="◄ 좌측 ►"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="▲" Command="{Binding DataContext.MoveHeaderButtonUpCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Grid.Column="4" Margin="0,0,4,0" Padding="6,2" Style="{StaticResource FluentSecondaryButtonStyle}"/>
                                            <Button Content="▼" Command="{Binding DataContext.MoveHeaderButtonDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Grid.Column="5" Padding="6,2" Style="{StaticResource FluentSecondaryButtonStyle}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Background="{DynamicResource SettingsHighlight}" Margin="0,16,0,16"/>
                            <TextBlock Text="사용자 커스텀 단축키" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="아이콘만 보이도록 표시하고, 툴팁과 접근성 이름은 커스텀할 수 있습니다." Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding CustomHeaderButtons}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding Visible}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"
                                                          Command="{Binding DataContext.SaveHeaderButtonsCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                <Border Grid.Column="1"
                                                        Width="36"
                                                        Height="28"
                                                        Margin="0,0,8,0"
                                                        Background="{DynamicResource SettingsHighlight}"
                                                        BorderBrush="{DynamicResource SettingsBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <TextBlock Text="{Binding EffectiveIconText}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SettingsFg}"/>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource SettingsFg}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding EffectiveAccessibleName}" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Button Grid.Column="3"
                                                        Margin="0,0,8,0"
                                                        Padding="8,2"
                                                        MinWidth="76"
                                                        Command="{Binding DataContext.ToggleHeaderButtonPositionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        VerticalAlignment="Center">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource FluentSecondaryButtonStyle}">
                                                            <Setter Property="Content" Value="◄ 우측 ►"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Position}" Value="Left">
                                                                    <Setter Property="Content" Value="◄ 좌측 ►"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="편집" Command="{Binding DataContext.EditCustomHeaderButtonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Grid.Column="4" Margin="0,0,4,0" Padding="8,2" Style="{StaticResource FluentSecondaryButtonStyle}"/>
                                                <Button Content="복제" Command="{Binding DataContext.DuplicateCustomHeaderButtonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Grid.Column="5" Margin="0,0,4,0" Padding="8,2" Style="{StaticResource FluentSecondaryButtonStyle}"/>
                                                <Button Content="▲" Command="{Binding DataContext.MoveHeaderButtonUpCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Grid.Column="6" Margin="0,0,4,0" Padding="6,2" Style="{StaticResource FluentSecondaryButtonStyle}"/>
                                                <StackPanel Grid.Column="7" Orientation="Horizontal">
                                                    <Button Content="▼" Command="{Binding DataContext.MoveHeaderButtonDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,4,0" Padding="6,2" Style="{StaticResource FluentSecondaryButtonStyle}"/>
                                                    <Button Content="삭제" Command="{Binding DataContext.RemoveCustomHeaderButtonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Padding="8,2" Style="{StaticResource FluentSecondaryButtonStyle}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Background="{DynamicResource SettingsHighlight}" Margin="0,16,0,16"/>
                            <TextBlock Text="상세 편집 진입" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="새 항목 추가는 아래 버튼으로, 기존 항목 수정은 각 행의 편집 버튼으로 독립 편집기를 엽니다." Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,8"/>
                            <Button x:Name="TopBarFirstFocusable"
                                    Content="새 커스텀 단축키 추가"
                                    Command="{Binding AddCustomHeaderButtonCommand}"
                                    Style="{StaticResource SettingsPrimaryButtonStyle}"
                                    HorizontalAlignment="Left"
                                    KeyboardNavigation.TabIndex="25"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="동작" AutomationProperties.Name="동작 설정 탭">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,10,8,10">
                            <TextBlock Text="입력/실행" Style="{StaticResource SectionTitleStyle}"/>

                            <TextBlock Text="전역 단축키" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="BehaviorFirstFocusable"
                                     Text="{Binding GlobalHotkey, UpdateSourceTrigger=LostFocus}"
                                     Height="30" Margin="0,0,0,16"
                                     Padding="8,4"
                                     Background="{DynamicResource SettingsHighlight}" Foreground="{DynamicResource SettingsFg}"
                                     BorderBrush="{DynamicResource SettingsBorder}"
                                     KeyboardNavigation.TabIndex="30"
                                     AutomationProperties.Name="전역 단축키 입력"/>

                            <CheckBox Content="Windows 시작 시 자동 실행"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding RunOnStartup}"
                                      Margin="0,0,0,16"
                                      KeyboardNavigation.TabIndex="31"
                                      AutomationProperties.Name="자동 실행"/>

                            <TextBlock Text="키 반복 입력" Style="{StaticResource SectionTitleStyle}"/>
                            <CheckBox Content="키 반복 입력 사용"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding KeyRepeatEnabled}"
                                      Margin="0,0,0,8" KeyboardNavigation.TabIndex="32"/>

                            <TextBlock Text="초기 지연" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="16,0,0,4"/>
                            <ctrl:NumericAdjuster Value="{Binding KeyRepeatDelayMs}" Minimum="100" Maximum="1000" Step="50" DecimalPlaces="0"
                                                  IsEnabled="{Binding KeyRepeatEnabled}"
                                                  Margin="16,0,0,8" KeyboardNavigation.TabIndex="33"/>

                            <TextBlock Text="반복 간격" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="16,0,0,4"/>
                            <ctrl:NumericAdjuster Value="{Binding KeyRepeatIntervalMs}" Minimum="20" Maximum="200" Step="10" DecimalPlaces="0"
                                                  IsEnabled="{Binding KeyRepeatEnabled}"
                                                  Margin="16,0,0,16" KeyboardNavigation.TabIndex="34"/>

                            <Separator Background="{DynamicResource SettingsHighlight}" Margin="0,0,0,16"/>

                            <TextBlock Text="체류 클릭" Style="{StaticResource SectionTitleStyle}"/>
                            <CheckBox Content="체류 클릭(Dwell Click)"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding DwellEnabled}"
                                      Margin="0,0,0,8" KeyboardNavigation.TabIndex="35"/>
                            <TextBlock Text="체류 시간" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="16,0,0,4"/>
                            <ctrl:NumericAdjuster Value="{Binding DwellTimeMs}" Minimum="200" Maximum="3000" Step="100" DecimalPlaces="0"
                                                  IsEnabled="{Binding DwellEnabled}"
                                                  Margin="16,0,0,16" KeyboardNavigation.TabIndex="36"/>

                            <Separator Background="{DynamicResource SettingsHighlight}" Margin="0,0,0,16"/>

                            <TextBlock Text="키 사운드" Style="{StaticResource SectionTitleStyle}"/>
                            <CheckBox Content="키 클릭 사운드"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding SoundEnabled}"
                                      Margin="0,0,0,8" KeyboardNavigation.TabIndex="37"/>
                            <StackPanel Orientation="Horizontal" Margin="16,0,0,16" Visibility="{Binding SoundEnabled, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="사운드 파일:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource SettingsFgSub}"/>
                                <TextBlock VerticalAlignment="Center" Opacity="0.7" MaxWidth="220" Foreground="{DynamicResource SettingsFg}" TextTrimming="CharacterEllipsis" Text="{Binding SoundFilePath}"/>
                                <Button Content="찾아보기" Command="{Binding BrowseSoundFileCommand}" Margin="8,0,0,0" Padding="8,4" Height="32" KeyboardNavigation.TabIndex="38"
                                        Style="{StaticResource FluentSecondaryButtonStyle}"/>
                                <Button Content="초기화" Command="{Binding ResetSoundFileCommand}" Margin="4,0,0,0" Padding="8,4" Height="32" KeyboardNavigation.TabIndex="39"
                                        Style="{StaticResource FluentSecondaryButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="보조기능" AutomationProperties.Name="보조기능 설정 탭">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,10,8,10">
                            <TextBlock Text="음성 안내(TTS)" Style="{StaticResource SectionTitleStyle}"/>
                            <CheckBox x:Name="A11yFirstFocusable"
                                      Content="키 선택 시 음성 안내 켜기"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding TtsEnabled}"
                                      Margin="0,0,0,8" KeyboardNavigation.TabIndex="50"/>
                            <CheckBox Content="마우스를 올려도 읽기"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding TtsOnHover}"
                                      IsEnabled="{Binding TtsEnabled}"
                                      Margin="16,0,0,8" KeyboardNavigation.TabIndex="51"/>
                            <TextBlock Text="음성 속도" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="16,0,0,4"/>
                            <ctrl:NumericAdjuster Value="{Binding TtsRate}" Minimum="-5" Maximum="5" Step="1" DecimalPlaces="0"
                                                  IsEnabled="{Binding TtsEnabled}"
                                                  Margin="16,0,0,16" KeyboardNavigation.TabIndex="52"/>

                            <Separator Background="{DynamicResource SettingsHighlight}" Margin="0,0,0,16"/>

                            <TextBlock Text="모션 최소화" Style="{StaticResource SectionTitleStyle}"/>
                            <CheckBox Content="모션 최소화 모드 켜기"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding ReducedMotionEnabled}"
                                      Margin="0,0,0,16" KeyboardNavigation.TabIndex="53"/>

                            <Separator Background="{DynamicResource SettingsHighlight}" Margin="0,0,0,16"/>

                            <TextBlock Text="포커스 탐색(키보드)" Style="{StaticResource SectionTitleStyle}"/>
                            <CheckBox Content="포커스 탐색 모드 활성화"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding KeyboardA11yNavigationEnabled}"
                                      Margin="0,0,0,8" KeyboardNavigation.TabIndex="54"/>
                            <Button Content="포커스 탐색 상세 설정 열기"
                                    Command="{Binding OpenFocusA11ySettingsCommand}"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Margin="16,0,0,8"
                                    IsEnabled="{Binding KeyboardA11yNavigationEnabled}"
                                    KeyboardNavigation.TabIndex="55"/>

                            <TextBlock Text="스위치 스캔 입력" Style="{StaticResource SectionTitleStyle}"/>
                            <CheckBox Content="스위치 스캔 입력 모드 켜기"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding SwitchScanEnabled}"
                                      Margin="0,0,0,8" KeyboardNavigation.TabIndex="56"/>
                            <Button Content="스위치 스캔 상세 설정 열기"
                                    Command="{Binding OpenSwitchScanSettingsCommand}"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Margin="16,0,0,8"
                                    IsEnabled="{Binding SwitchScanEnabled}"
                                    KeyboardNavigation.TabIndex="57"/>
                            <TextBlock Text="LiveRegion 공지 모드" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="16,0,0,4"/>
                            <ComboBox ItemsSource="{Binding SwitchScanAnnounceModes}" SelectedItem="{Binding SwitchScanAnnounceMode}" Margin="16,0,0,8" Height="30" KeyboardNavigation.TabIndex="58"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="AI 도구" AutomationProperties.Name="AI 도구 설정 탭">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,10,8,10">
                            <TextBlock Text="AI 텍스트 처리" Style="{StaticResource SectionTitleStyle}"/>
                            <CheckBox Content="AI 도구 활성화 (상단바 ✨ 표시)"
                                      Foreground="{DynamicResource SettingsFg}"
                                      IsChecked="{Binding AiEnabled}"
                                      Margin="0,0,0,16"/>
                            
                            <StackPanel IsEnabled="{Binding AiEnabled}">
                                <TextBlock Text="API 엔드포인트 URL (OpenAI 호환)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding AiEndpoint, UpdateSourceTrigger=LostFocus}" Height="30" Margin="0,0,0,16" Padding="8,4" Background="{DynamicResource SettingsHighlight}" Foreground="{DynamicResource SettingsFg}" BorderBrush="{DynamicResource SettingsBorder}"/>

                                <TextBlock Text="API 키 (Windows DPAPI 암호화 저장, 로컬 서버시 비움)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding AiApiKey, UpdateSourceTrigger=LostFocus}" Height="30" Margin="0,0,0,16" Padding="8,4" Background="{DynamicResource SettingsHighlight}" Foreground="{DynamicResource SettingsFg}" BorderBrush="{DynamicResource SettingsBorder}"/>

                                <TextBlock Text="모델 이름 (예: gpt-4o-mini, llama3 등)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding AiModel, UpdateSourceTrigger=LostFocus}" Height="30" Margin="0,0,0,16" Padding="8,4" Background="{DynamicResource SettingsHighlight}" Foreground="{DynamicResource SettingsFg}" BorderBrush="{DynamicResource SettingsBorder}"/>

                                <TextBlock Text="기본 프롬프트 (AI 동작 지시)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding AiDefaultPrompt, UpdateSourceTrigger=LostFocus}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8" Padding="8,4" Background="{DynamicResource SettingsHighlight}" Foreground="{DynamicResource SettingsFg}" BorderBrush="{DynamicResource SettingsBorder}"/>
                                <Button Content="긴 한글 프롬프트 편집기 열기"
                                        Command="{Binding OpenAiPromptEditorCommand}"
                                        Style="{StaticResource SettingsActionButtonStyle}"
                                        Margin="0,0,0,4"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.Name="AI 프롬프트 편집기 열기"
                                        ToolTip="한글 조합이 긴 프롬프트는 AltKey.Tools의 독립 편집기에서 더 안정적으로 입력할 수 있습니다."/>
                                <TextBlock Text="긴 한글 프롬프트는 독립 편집기에서 저장하면 설정 창에도 즉시 반영됩니다."
                                           Foreground="{DynamicResource SettingsFgSub}"
                                           FontSize="11"
                                           Margin="0,0,0,16"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="타임아웃 (초)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                                <ctrl:NumericAdjuster Value="{Binding AiTimeoutSeconds}" Minimum="5" Maximum="300" Step="5" DecimalPlaces="0"
                                                      Margin="0,0,0,8"/>
                                <Button Content="연결 테스트 (짧은 API 요청)"
                                        Command="{Binding TestAiConnectionCommand}"
                                        Style="{StaticResource SettingsActionButtonStyle}"
                                        Margin="0,0,0,16"
                                        HorizontalAlignment="Left"
                                        ToolTip="엔드포인트·모델·API 키가 올바른지 확인합니다. 먼저 위 항목을 입력한 뒤 눌러 주세요."/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="고급" AutomationProperties.Name="고급 설정 탭">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,10,8,10">
                            <TextBlock Text="업데이트" Style="{StaticResource SectionTitleStyle}"/>

                            <Border Background="{DynamicResource SettingsHighlight}" CornerRadius="6" Padding="12,8" Margin="0,0,0,8" Visibility="{Binding IsCheckingUpdate, Converter={StaticResource InvBoolToVis}}">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock x:Name="AdvancedFirstFocusable" Text="{Binding UpdateStatusMessage}" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SettingsFg}" Focusable="True" KeyboardNavigation.TabIndex="70"/>
                                    <TextBlock Text="{Binding LatestVersion, StringFormat=최신 버전: {0}}" FontSize="11" Foreground="{DynamicResource SettingsFgSub}" Margin="0,4,0,0"
                                               Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Vertical" Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding UpdateStatusMessage}" FontSize="12" Foreground="{DynamicResource SettingsFg}" Margin="0,0,0,4"/>
                                <ProgressBar Height="20" Value="{Binding DownloadProgress}" Minimum="0" Maximum="1" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding DownloadProgress, StringFormat={}{0:P0}}" FontSize="11" Foreground="{DynamicResource SettingsFgSub}"/>
                            </StackPanel>

                            <TextBlock Text="설치 중에는 앱이 자동으로 종료 후 재시작될 수 있습니다." FontSize="12" Foreground="{DynamicResource SettingsFg}" FontWeight="SemiBold"
                                       Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16" Visibility="{Binding IsDownloading, Converter={StaticResource InvBoolToVis}}">
                                <Button Content="업데이트 확인" Command="{Binding CheckForUpdateCommand}" Style="{StaticResource SettingsActionButtonStyle}" KeyboardNavigation.TabIndex="71"
                                        Margin="0,0,8,0"/>
                                <Button Content="자동 설치" Command="{Binding DownloadAndInstallFromSettingsCommand}" Style="{StaticResource SettingsPrimaryButtonStyle}" KeyboardNavigation.TabIndex="72"
                                        Margin="0,0,8,0"
                                        Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolToVis}}"/>
                                <Button Content="GitHub" Command="{Binding OpenReleasePageCommand}" Style="{StaticResource SettingsActionButtonStyle}" KeyboardNavigation.TabIndex="73"
                                        Margin="0,0,8,0"
                                        Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolToVis}}"/>
                                <Button Content="취소" Command="{Binding CancelDownloadCommand}" Style="{StaticResource SettingsActionButtonStyle}" KeyboardNavigation.TabIndex="74"
                                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <TextBlock Text="프로필 레이아웃" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="프로필 매핑 편집은 독립 도구(AltKey.Tools)에서 관리합니다."
                                       Foreground="{DynamicResource SettingsFgSub}"
                                       FontSize="11"
                                       Margin="0,0,0,8"/>
                            <Button Content="프로필 매핑 편집기 열기"
                                    Command="{Binding OpenProfileMappingEditorCommand}"
                                    Style="{StaticResource SettingsActionButtonStyle}"
                                    Margin="0,0,0,16"
                                    KeyboardNavigation.TabIndex="75"
                                    AutomationProperties.Name="프로필 매핑 편집기 열기"
                                    ToolTip="프로세스 이름과 레이아웃 이름 매핑을 독립 편집 창에서 수정합니다."/>

                            <Separator Background="{DynamicResource SettingsHighlight}" Margin="0,0,0,16"/>
                            <Button Content="사용자 설정 데이터 폴더 열기"
                                    Command="{Binding OpenUserSettingsFolderCommand}"
                                    Style="{StaticResource SettingsActionButtonStyle}" Margin="0,0,0,8" KeyboardNavigation.TabIndex="77"
                                    ToolTip="레이아웃, 사용자 단어, 통계 등 사용자 설정 파일이 있는 폴더를 엽니다."/>

                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SettingsFg}" Opacity="0.75" Margin="0,0,0,4"
                                       Text="창 위치 또는 크기가 비정상적으로 보이면 창 레이아웃을 초기화할 수 있습니다. 자동완성은 꺼지고 앱이 재시작됩니다."/>
                            <Button Content="창 레이아웃 초기화" Command="{Binding ResetWindowLayoutCommand}" Style="{StaticResource SettingsActionButtonStyle}" KeyboardNavigation.TabIndex="78"
                                    Margin="0,0,0,16"/>

                            <Border Background="{DynamicResource AdminWarningBg}" CornerRadius="6" Padding="12,8" Margin="0,0,0,8" Visibility="{Binding IsRunningAsAdmin, Converter={StaticResource InvBoolToVis}}">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource AdminWarningFg}"
                                           Text="보안 프로그램이나 관리자 권한 창에서 입력이 되지 않으면 관리자 권한으로 재시작해 보세요."/>
                            </Border>
                            <Button Content="관리자 권한으로 재시작" Command="{Binding RestartAsAdminCommand}" Style="{StaticResource SettingsActionButtonStyle}" KeyboardNavigation.TabIndex="79"
                                    Visibility="{Binding IsRunningAsAdmin, Converter={StaticResource InvBoolToVis}}" Margin="0,0,0,8"/>

                            <Border Background="{DynamicResource AdminOkBg}" CornerRadius="6" Padding="12,8" Margin="0,0,0,8" Visibility="{Binding IsRunningAsAdmin, Converter={StaticResource BoolToVis}}">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource AdminOkFg}"
                                           Text="현재 관리자 권한으로 실행 중입니다. 일반 앱 입력 호환성을 위해 일반 권한 실행을 권장합니다."/>
                            </Border>
                            <Button Content="일반 권한으로 재시작" Command="{Binding RestartAsUserCommand}" Style="{StaticResource SettingsActionButtonStyle}" KeyboardNavigation.TabIndex="80"
                                    Visibility="{Binding IsRunningAsAdmin, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
