<UserControl x:Class="AltKey.Views.ActionBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:AltKey.ViewModels"
             xmlns:ctrl="clr-namespace:AltKey.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ActionBuilderViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- 공통 입력 스타일 -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"   Value="#33FFFFFF"/>
            <Setter Property="Foreground"   Value="#EEFFFFFF"/>
            <Setter Property="BorderBrush"  Value="#55FFFFFF"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
        </Style>
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Margin"       Value="0,0,0,6"/>
            <Setter Property="Height"       Value="26"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#88FFFFFF"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="Margin"       Value="0,0,0,2"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>

        <!-- 액션 타입 선택 -->
        <TextBlock Text="액션 타입" Style="{StaticResource HintText}"/>
        <ComboBox ItemsSource="{Binding ActionTypes}"
                  SelectedItem="{Binding SelectedActionType}"
                  Style="{StaticResource InputCombo}"/>

        <!-- ── SendKey ── -->
        <StackPanel Visibility="{Binding IsSendKey, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="가상 키 코드 (예: VK_A, Ctrl+A, A)" Style="{StaticResource HintText}"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding CommonVkCodesDisplay}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="VkCode"
                          SelectedValue="{Binding SendKeyVk}"
                          Width="120" Margin="0,0,6,0"
                          IsEditable="True"/>
                <TextBox Grid.Column="1"
                         Text="{Binding SendKeyVk, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputBox}"/>
            </Grid>
        </StackPanel>

        <!-- ── SendCombo ── -->
        <StackPanel Visibility="{Binding IsSendCombo, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="키 조합 (예: Ctrl+A, Shift+B)" Style="{StaticResource HintText}"/>
            <ItemsControl ItemsSource="{Binding SendComboKeysCollection}" Margin="0,0,0,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding DataContext.CommonVkCodesDisplay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="VkCode"
                                      SelectedValue="{Binding Path=Value, Mode=TwoWay}"
                                      IsEditable="True"
                                      Margin="0,0,4,0"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Padding="6,2"
                                    Background="#33FFFFFF" Foreground="#EEFFFFFF"
                                    BorderThickness="0" Cursor="Hand"
                                    Command="{Binding DataContext.RemoveComboKeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="+ 키 추가"
                    Padding="6,4"
                    Background="#33FFFFFF" Foreground="#EEFFFFFF"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding AddComboKeyCommand}"
                    HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- ── ToggleSticky ── -->
        <StackPanel Visibility="{Binding IsToggleSticky, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="수식자 키 (예: VK_SHIFT, Shift, Ctrl)" Style="{StaticResource HintText}"/>
            <ComboBox ItemsSource="{Binding CommonVkCodesDisplay}"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="VkCode"
                      SelectedValue="{Binding ToggleStickyVk}"
                      IsEditable="True"
                      Style="{StaticResource InputCombo}"/>
        </StackPanel>

        <!-- ── SwitchLayout ── -->
        <StackPanel Visibility="{Binding IsSwitchLayout, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="레이아웃 파일명 (확장자 없이)" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding SwitchLayoutName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBox}"/>
        </StackPanel>

        <!-- ── RunApp ── -->
        <StackPanel Visibility="{Binding IsRunApp, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="실행 파일 경로" Style="{StaticResource HintText}"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding AppPath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Column="0" Margin="0"
                         Background="#33FFFFFF" Foreground="#EEFFFFFF"
                         BorderBrush="#55FFFFFF" Padding="6,4"/>
                <Button Content="찾아보기"
                        Grid.Column="1" Margin="4,0,0,0"
                        Padding="6,4"
                        Background="#33FFFFFF" Foreground="#EEFFFFFF"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding BrowseAppCommand}"/>
            </Grid>
            <TextBlock Text="실행 인수 (선택)" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding AppArgs, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBox}"/>
        </StackPanel>

        <!-- ── Boilerplate ── -->
        <StackPanel Visibility="{Binding IsBoilerplate, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="입력할 텍스트" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding BoilerplateText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                     Background="#33FFFFFF" Foreground="#EEFFFFFF"
                     BorderBrush="#55FFFFFF" Padding="6,4"
                     Margin="0,0,0,6"/>
        </StackPanel>

        <!-- ── ShellCommand ── -->
        <StackPanel Visibility="{Binding IsShellCommand, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="명령어 (예: shutdown /s /t 300)" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding ShellCmd, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBox}"/>
            <TextBlock Text="셸 종류" Style="{StaticResource HintText}"/>
            <ComboBox ItemsSource="{Binding ShellTypes}"
                      SelectedItem="{Binding SelectedShell}"
                      Style="{StaticResource InputCombo}"/>
        </StackPanel>

        <!-- ── VolumeControl ── -->
        <StackPanel Visibility="{Binding IsVolumeControl, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="방향 (up / down / mute)" Style="{StaticResource HintText}"/>
            <ComboBox ItemsSource="{Binding VolumeDirections}"
                      SelectedItem="{Binding VolumeDirection}"
                      Style="{StaticResource InputCombo}"/>
            <TextBlock Text="단계" Style="{StaticResource HintText}"/>
            <ctrl:NumericAdjuster Value="{Binding VolumeStep}"
                                  Minimum="2" Maximum="20" Step="1" DecimalPlaces="0"
                                  ButtonBackground="#33FFFFFF"
                                  ButtonForeground="#EEFFFFFF"
                                  TextBoxBackground="#33FFFFFF"
                                  TextBoxForeground="#EEFFFFFF"
                                  TextBoxBorderBrush="#55FFFFFF"
                                  Margin="0,0,0,6"/>
        </StackPanel>

        <!-- ── ClipboardPaste ── -->
        <StackPanel Visibility="{Binding IsClipboardPaste, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="붙여넣을 텍스트" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding ClipboardText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                     Background="#33FFFFFF" Foreground="#EEFFFFFF"
                     BorderBrush="#55FFFFFF" Padding="6,4"
                     Margin="0,0,0,6"/>
        </StackPanel>

        <!-- ── ToggleKoreanSubmode ── -->
        <StackPanel Visibility="{Binding IsToggleKoreanSubmode, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="한/영 입력 모드 전환 키 (파라미터 없음)" Style="{StaticResource HintText}"/>
        </StackPanel>

    </StackPanel>
</UserControl>
