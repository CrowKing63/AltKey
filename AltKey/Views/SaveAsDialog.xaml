<Window x:Class="AltKey.Views.SaveAsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="다른 이름으로 저장"
        Width="340" Height="140"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1E1E2E"
        ShowInTaskbar="False">
    <StackPanel Margin="20,16">
        <TextBlock Text="파일명 (확장자 없이):"
                   Foreground="#AAFFFFFF" FontSize="11" Margin="0,0,0,4"/>
        <TextBox x:Name="FileNameBox"
                 Background="#33FFFFFF" Foreground="#EEFFFFFF"
                 BorderBrush="#55FFFFFF" Padding="6,5"
                 FontSize="13" Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" IsCancel="True"
                    Padding="14,5" Margin="0,0,6,0" Cursor="Hand"
                    Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderThickness="0"
                    Click="CancelButton_Click"/>
            <Button Content="저장" IsDefault="True"
                    Padding="14,5" Cursor="Hand"
                    Background="#3B82F6" Foreground="White" BorderThickness="0"
                    Click="OkButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
