<UserControl x:Class="AltKey.Views.KeyboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AltKey.ViewModels"
             xmlns:controls="clr-namespace:AltKey.Controls"
             xmlns:views="clr-namespace:AltKey.Views"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="320">

    <Grid>
        <!-- м „мІҙ м°Ҫ л°°кІҪ -->
        <Border Background="{DynamicResource WindowBg}" IsHitTestVisible="False"/>

        <!-- л©”мқё л Ҳмқҙм•„мӣғ: DockPanel (нҢЁл„җ мҳҒм—ӯ вҶ’ нӮӨліҙл“ң мҲңмңјлЎң мң„м—җм„ң м•„лһҳлЎң) -->
        <DockPanel LastChildFill="True">

            <!-- мғҒлӢЁ н—ӨлҚ” л°”: л“ңлһҳк·ё н•ёл“Ө + лІ„нҠјл“Ө (T-1.5, T-4.8, T-7.2) -->
            <Grid DockPanel.Dock="Top" Height="28">
                <!-- л“ңлһҳк·ё н•ёл“Ө (л°°кІҪ мҳҒм—ӯ м „мІҙ) -->
                <Border x:Name="DragHandle"
                        Background="Transparent"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="DragHandle_MouseLeftButtonDown"
                        MouseEnter="DragHandle_MouseEnter"
                        MouseLeave="DragHandle_MouseLeave">
                    <Grid>
                        <!-- м•ұ нғҖмқҙнӢҖ + м—…лҚ°мқҙнҠё мқёл””мјҖмқҙн„° (мўҢмёЎ) -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <TextBlock Text="AltKey" Foreground="{DynamicResource TitleFg}"
                                       FontSize="11" IsHitTestVisible="False"/>
                            <!-- м—…лҚ°мқҙнҠё мһҲмқ„ л•Ңл§Ң н‘ңмӢңлҗҳлҠ” лҜёлӢҲ мқёл””мјҖмқҙн„° лІ„нҠј -->
                            <Button Width="14" Height="14" Margin="5,0,0,1"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" IsHitTestVisible="True"
                                    Command="{Binding DownloadAndInstallUpdateCommand}"
                                    Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}"
                                    ToolTip="{Binding UpdateIndicatorTooltip}">
                                <Grid>
                                    <!-- м—…лҚ°мқҙнҠё лҢҖкё° мӨ‘: мЈјнҷ© м җ -->
                                    <Ellipse Width="8" Height="8" Fill="#FFF97316"
                                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                    <!-- лӢӨмҡҙлЎңл“ң мӨ‘: нҢҢлһҖ м җ -->
                                    <Ellipse Width="8" Height="8" Fill="#FF2563EB"
                                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Button>
                        </StackPanel>

                        <!-- мӨ‘м•ҷ: мң„м№ҳ мқҙлҸҷ лІ„нҠј + T-4.8 pill мқёл””мјҖмқҙн„° -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Panel.ZIndex="1">
                            <Button Width="18" Height="18" Content="вҶҗ" ToolTip="нҷ”л©ҙ мҷјмӘҪмңјлЎң мқҙлҸҷ"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TitleFg}" Opacity="0.45"
                                    Cursor="Hand" Padding="0" FontSize="10"
                                    Click="EdgeLeftBtn_Click"
                                    AutomationProperties.Name="мҷјмӘҪмңјлЎң мқҙлҸҷ"/>
                            <Button Width="18" Height="18" Content="вҶ‘" ToolTip="нҷ”л©ҙ мң„мӘҪмңјлЎң мқҙлҸҷ"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TitleFg}" Opacity="0.45"
                                    Cursor="Hand" Padding="0" FontSize="10"
                                    Click="EdgeUpBtn_Click"
                                    AutomationProperties.Name="мң„мӘҪмңјлЎң мқҙлҸҷ"/>
                            <Rectangle x:Name="DragPill"
                                       Width="36" Height="4"
                                       Fill="{DynamicResource TitleFg}"
                                       Opacity="0.25"
                                       RadiusX="2" RadiusY="2"
                                       Margin="6,0"
                                       VerticalAlignment="Center"
                                        IsHitTestVisible="False"/>
                            <Button Width="18" Height="18" Content="вҶ“" ToolTip="нҷ”л©ҙ м•„лһҳмӘҪмңјлЎң мқҙлҸҷ"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TitleFg}" Opacity="0.45"
                                    Cursor="Hand" Padding="0" FontSize="10"
                                    Click="EdgeDownBtn_Click"
                                    AutomationProperties.Name="м•„лһҳмӘҪмңјлЎң мқҙлҸҷ"/>
                            <Button Width="18" Height="18" Content="вҶ’" ToolTip="нҷ”л©ҙ мҳӨлҘёмӘҪмңјлЎң мқҙлҸҷ"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TitleFg}" Opacity="0.45"
                                    Cursor="Hand" Padding="0" FontSize="10"
                                    Click="EdgeRightBtn_Click"
                                    AutomationProperties.Name="мҳӨлҘёмӘҪмңјлЎң мқҙлҸҷ"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- T-5.10 / T-7.2: кё°м–ҙ(м„Өм •) лІ„нҠј -->
                <Button x:Name="SettingsButton" Width="32" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,248,0"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding ToggleSettingsCommand}"
                        ToolTip="м„Өм •"
                        AutomationProperties.Name="м„Өм •">
                    <TextBlock Text="вҡҷ" FontSize="14"/>
                </Button>

                <!-- T-8.3: мқҙлӘЁм§Җ нҢЁл„җ нҶ кёҖ лІ„нҠј -->
                <Button Width="32" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,208,0"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding ToggleEmojiPanelCommand}"
                        ToolTip="мқҙлӘЁм§Җ нҢЁл„җ"
                        AutomationProperties.Name="мқҙлӘЁм§Җ нҢЁл„җ">
                    <TextBlock Text="рҹҳҠ" FontSize="14"/>
                </Button>

                <!-- T-8.4: нҒҙлҰҪліҙл“ң нҢЁл„җ нҶ кёҖ лІ„нҠј -->
                <Button Width="32" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,168,0"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding ToggleClipboardPanelCommand}"
                        ToolTip="нҒҙлҰҪліҙл“ң нҢЁл„җ"
                        AutomationProperties.Name="нҒҙлҰҪліҙл“ң нҢЁл„җ">
                    <TextBlock Text="рҹ“Ӣ" FontSize="14"/>
                </Button>

                <!-- 07: OS IME н•ң/мҳҒ л№„мғҒ лІ„нҠј -->
                <Button Width="40" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,80,0"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding SendOsImeHangulCommand}"
                        ToolTip="OS IME н•ң/мҳҒ м „нҷҳ (кұ°мқҳ м“ё мқјмқҙ м—ҶлҠ” л№„мғҒ лІ„нҠј)"
                        AutomationProperties.Name="OS IME н•ңмҳҒ м „нҷҳ"
                        AutomationProperties.HelpText="кұ°мқҳ мӮ¬мҡ©н•  мқјмқҙ м—ҶлҠ” л№„мғҒмҡ© лІ„нҠјмһ…лӢҲлӢӨ.">
                    <TextBlock Text="н•ң/мҳҒ" FontSize="10"/>
                </Button>

                <!-- T-9.3 / 06: мһҗлҸҷмҷ„м„ұ нҶ кёҖ лІ„нҠј -->
                <ToggleButton Width="32" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,128,0"
                        Background="{Binding AutoCompleteEnabled, Converter={StaticResource BoolToVis}, ConverterParameter=Background}"
                        Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        IsChecked="{Binding AutoCompleteEnabled, Mode=TwoWay}"
                        IsEnabled="{Binding CanToggleAutoComplete}"
                        ToolTip="мһҗлҸҷмҷ„м„ұ (мң лӢҲмҪ”л“ң м§Ғм ‘ мһ…л Ҙ) мјңкё°/лҒ„кё°"
                        AutomationProperties.Name="мһҗлҸҷмҷ„м„ұ нҶ кёҖ"
                        AutomationProperties.HelpText="мјңл©ҙ мң лӢҲмҪ”л“ң м§Ғм ‘ мһ…л Ҙ, лҒ„л©ҙ OS IME мӮ¬мҡ©">
                    <TextBlock Text="AC" FontWeight="Bold" FontSize="12"/>
                </ToggleButton>

                <!-- T-7.2: м ‘кё°/нҺјм№ҳкё° лІ„нҠј -->
                <Button x:Name="CollapseButton" Width="32" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,32,0"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Click="CollapseButton_Click"
                        ToolTip="м ‘кё° / нҺјм№ҳкё°"
                        AutomationProperties.Name="м ‘кё° нҺјм№ҳкё°">
                    <TextBlock x:Name="CollapseIcon" Text="в–І" FontSize="10"/>
                </Button>

                <!-- T-7.2: лӢ«кё° лІ„нҠј вҶ’ нҠёл ҲмқҙлЎң мҲЁкё°кё° -->
                <Button x:Name="CloseButton" Width="32" Height="28"
                        HorizontalAlignment="Right"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Click="CloseButton_Click"
                        ToolTip="лӢ«кё° (нҠёл ҲмқҙлЎң мҲЁк№Җ)"
                        AutomationProperties.Name="лӢ«кё°">
                    <TextBlock Text="вң•" FontSize="14"/>
                </Button>
            </Grid>

            <!-- T-9.3: мһҗлҸҷ мҷ„м„ұ м ңм•Ҳ л°” (м ңм•Ҳмқҙ мһҲмқ„ л•Ңл§Ң н‘ңмӢң) -->
            <views:SuggestionBar
                x:Name="AutoCompleteBar"
                DockPanel.Dock="Top"
                DataContext="{Binding AutoComplete}"
                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                Height="{Binding DataContext.Keyboard.KeyRowHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

            <!-- 08: LiveRegion кіөм§Җ (Narratorмҡ©) -->
            <TextBlock x:Name="ModeAnnouncer"
                       Text="{Binding Keyboard.ModeAnnouncement}"
                       Opacity="0"
                       IsHitTestVisible="False"
                       AutomationProperties.LiveSetting="Polite"
                       Width="0" Height="0"/>

            <!-- T-2.10: UAC к¶Ңн•ң кІҪкі  л°°л„Ҳ (Auto лҶ’мқҙ, мҲЁк№Җ мӢң кіөк°„ м—ҶмқҢ) -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource ElevatedWarningBg}" CornerRadius="4"
                    Padding="12,6"
                    Visibility="{Binding Keyboard.ShowElevatedWarning, Converter={StaticResource BoolToVis}}">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ElevatedWarningFg}"
                           Text="нӮӨліҙл“ң ліҙм•Ҳ н”„лЎңк·ёлһЁмқҙлӮҳ кҙҖлҰ¬мһҗ к¶Ңн•ң м•ұм—җм„ң мһ…л Ҙмқҙ м°ЁлӢЁлҗҳм—ҲмҠөлӢҲлӢӨ. AltKeyлҘј кҙҖлҰ¬мһҗ к¶Ңн•ңмңјлЎң мӢӨн–үн•ҙ ліҙм„ёмҡ”."/>
            </Border>

            <!-- T-3.7 / T-4.10: нӮӨліҙл“ң л ҢлҚ”л§Ғ (лӮҳлЁём§Җ кіөк°„ мұ„мҡ°кё°) -->
            <Border x:Name="KeyboardBorder"
                    Background="{DynamicResource KeyboardBg}"
                    CornerRadius="0,0,8,8" Padding="6,4"
                    SizeChanged="KeyboardBorder_SizeChanged"
                    MouseLeftButtonDown="KeyboardBorder_MouseLeftButtonDown">
                <ItemsControl ItemsSource="{Binding Keyboard.Columns}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:KeyColumnVm}">
                            <StackPanel Orientation="Vertical"
                                        Margin="{Binding Gap, Converter={StaticResource GapToRightMargin}}">
                                <ItemsControl ItemsSource="{Binding Rows}"
                                              HorizontalAlignment="Center">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:KeyRowVm}">
                                            <ItemsControl ItemsSource="{Binding Keys}"
                                                          HorizontalAlignment="Center"
                                                          MinHeight="{Binding DataContext.Keyboard.KeyRowHeight,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:KeySlotVm}">
                                                  <controls:KeyButton
                                                      Slot="{Binding}"
                                                      ShowUpperCase="{Binding DataContext.Keyboard.ShowUpperCase,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      DisplayLabel="{Binding DisplayLabel}"
                                                      SubLabel="{Binding SubLabelText}"
                                                      IsDimmed="{Binding IsDimmed}"
                                                      IsSticky="{Binding IsSticky}"
                                                      IsLocked="{Binding IsLocked}"
                                                      KeyUnit="{Binding DataContext.Keyboard.KeyUnit,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      DwellEnabled="{Binding DataContext.DwellEnabled,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      DwellTime="{Binding DataContext.DwellTimeMs,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      KeyRepeatEnabled="{Binding DataContext.KeyRepeatEnabled,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      KeyRepeatDelayMs="{Binding DataContext.KeyRepeatDelayMs,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      KeyRepeatIntervalMs="{Binding DataContext.KeyRepeatIntervalMs,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      Command="{Binding DataContext.Keyboard.KeyPressedCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding Slot}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </Border>

        </DockPanel>

        <!-- T-8.3: мқҙлӘЁм§Җ нҢЁл„җ мҳӨлІ„л Ҳмқҙ (н—ӨлҚ” л°” л°”лЎң м•„лһҳ, нӮӨліҙл“ң мң„м—җ н‘ңмӢң) -->
        <views:EmojiPanel
            DataContext="{Binding Emoji}"
            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
            VerticalAlignment="Top"
            Margin="0,28,0,0"
            Panel.ZIndex="6"/>

        <!-- T-8.4: нҒҙлҰҪліҙл“ң нҢЁл„җ мҳӨлІ„л Ҳмқҙ (н—ӨлҚ” л°” л°”лЎң м•„лһҳ, мўҢмёЎ л°°м№ҳ) -->
        <views:ClipboardPanel
            DataContext="{Binding Clipboard}"
            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
            Width="240"
            Margin="0,28,0,0"
            Panel.ZIndex="6"/>

        <!-- T-5.10: м„Өм • нҢЁл„җ мҳӨлІ„л Ҳмқҙ (нӮӨліҙл“ң м „мІҙ мң„м—җ н‘ңмӢң) -->
        <views:SettingsView
            x:Name="SettingsPanel"
            DataContext="{Binding Settings}"
            Visibility="{Binding DataContext.IsSettingsOpen,
                RelativeSource={RelativeSource AncestorType=UserControl},
                Converter={StaticResource BoolToVis}}"
            Panel.ZIndex="10"
            Margin="8,4,8,4"/>

    </Grid>
</UserControl>
