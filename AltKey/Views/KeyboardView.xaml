<UserControl x:Class="AltKey.Views.KeyboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AltKey.ViewModels"
             xmlns:controls="clr-namespace:AltKey.Controls"
             xmlns:views="clr-namespace:AltKey.Views"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="320">

    <Grid>
        <!-- 전체 창 배경 -->
        <Border Background="{DynamicResource WindowBg}" IsHitTestVisible="False"/>

        <!-- 메인 레이아웃: DockPanel (패널 영역 → 키보드 순으로 위에서 아래로) -->
        <DockPanel LastChildFill="True">

            <!-- T-9.5: 업데이트 알림 배너 (ViewModel 바인딩) -->
            <Border DockPanel.Dock="Top"
                    Background="#FF2563EB"
                    Padding="8,4"
                    Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="20">
                <StackPanel Orientation="Horizontal">
                    <!-- 기본 업데이트 메시지 -->
                    <TextBlock x:Name="UpdateMessageText"
                               Text="{Binding UpdateVersion, StringFormat='새 버전이 있습니다: {0}'}"
                               Foreground="White" VerticalAlignment="Center"
                               Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                    
                    <!-- 다운로드 버튼 (다운로드 중이 아닐 때만 표시) -->
                    <Button Content="자동 설치"
                            Command="{Binding DownloadAndInstallUpdateCommand}"
                            Margin="8,0,0,0" Padding="6,2"
                            Background="#1D4ED8" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                    
                    <!-- GitHub 다운로드 버튼 -->
                    <Button Content="GitHub"
                            Command="{Binding OpenReleasePageCommand}"
                            Margin="4,0,0,0" Padding="6,2"
                            Background="#1D4ED8" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                    
                    <!-- 닫기 버튼 -->
                    <Button Content="✕"
                            Command="{Binding DismissUpdateCommand}"
                            Margin="4,0,0,0" Padding="4,2"
                            Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                    <!-- 다운로드 진행률 표시 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding UpdateStatusMessage}" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ProgressBar Width="150" Height="16" 
                                     Value="{Binding DownloadProgress}"
                                     Minimum="0" Maximum="1"/>
                        <TextBlock Text="{Binding DownloadProgress, StringFormat={}{0:P0}}" 
                                   Foreground="White" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <Button Content="취소"
                                Command="{Binding CancelDownloadCommand}"
                                Margin="8,0,0,0" Padding="4,2"
                                Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>

                    <!-- 설치 중 표시 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="설치 중... 앱이 자동으로 종료됩니다." 
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 상단 헤더 바: 드래그 핸들 + 버튼들 (T-1.5, T-4.8, T-7.2) -->
            <Grid DockPanel.Dock="Top" Height="28">
                <!-- 드래그 핸들 (배경 영역 전체) -->
                <Border x:Name="DragHandle"
                        Background="Transparent"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="DragHandle_MouseLeftButtonDown"
                        MouseEnter="DragHandle_MouseEnter"
                        MouseLeave="DragHandle_MouseLeave">
                    <Grid>
                        <!-- 앱 타이틀 (좌측) -->
                        <TextBlock Text="AltKey" HorizontalAlignment="Left" VerticalAlignment="Center"
                                   Margin="12,0,0,0" Foreground="{DynamicResource TitleFg}"
                                   FontSize="11" IsHitTestVisible="False"/>

                        <!-- 중앙: 위치 이동 버튼 + T-4.8 pill 인디케이터 -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Panel.ZIndex="1">
                            <Button Width="18" Height="18" Content="←" ToolTip="화면 왼쪽으로 이동"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TitleFg}" Opacity="0.45"
                                    Cursor="Hand" Padding="0" FontSize="10"
                                    Click="EdgeLeftBtn_Click"/>
                            <Button Width="18" Height="18" Content="↑" ToolTip="화면 위쪽으로 이동"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TitleFg}" Opacity="0.45"
                                    Cursor="Hand" Padding="0" FontSize="10"
                                    Click="EdgeUpBtn_Click"/>
                            <Rectangle x:Name="DragPill"
                                       Width="36" Height="4"
                                       Fill="{DynamicResource TitleFg}"
                                       Opacity="0.25"
                                       RadiusX="2" RadiusY="2"
                                       Margin="6,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                            <Button Width="18" Height="18" Content="↓" ToolTip="화면 아래쪽으로 이동"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TitleFg}" Opacity="0.45"
                                    Cursor="Hand" Padding="0" FontSize="10"
                                    Click="EdgeDownBtn_Click"/>
                            <Button Width="18" Height="18" Content="→" ToolTip="화면 오른쪽으로 이동"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TitleFg}" Opacity="0.45"
                                    Cursor="Hand" Padding="0" FontSize="10"
                                    Click="EdgeRightBtn_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- T-5.10 / T-7.2: 기어(설정) 버튼 -->
                <Button x:Name="SettingsButton" Width="32" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,248,0"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding ToggleSettingsCommand}"
                        ToolTip="설정">
                    <TextBlock Text="⚙" FontSize="14"/>
                </Button>

                <!-- T-8.3: 이모지 패널 토글 버튼 -->
                <Button Width="32" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,208,0"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding ToggleEmojiPanelCommand}"
                        ToolTip="이모지 패널">
                    <TextBlock Text="😊" FontSize="14"/>
                </Button>

                <!-- T-8.4: 클립보드 패널 토글 버튼 -->
                <Button Width="32" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,168,0"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding ToggleClipboardPanelCommand}"
                        ToolTip="클립보드 패널">
                    <TextBlock Text="📋" FontSize="14"/>
                </Button>

                <!-- 07: OS IME 한/영 비상 버튼 -->
                <Button Width="40" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,80,0"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding SendOsImeHangulCommand}"
                        ToolTip="OS IME 한/영 전환 (거의 쓸 일이 없는 비상 버튼)">
                    <TextBlock Text="한/영" FontSize="10"/>
                </Button>

                <!-- T-9.3 / 06: 자동완성 토글 버튼 -->
                <ToggleButton Width="32" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,128,0"
                        Background="{Binding AutoCompleteEnabled, Converter={StaticResource BoolToVis}, ConverterParameter=Background}"
                        Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        IsChecked="{Binding AutoCompleteEnabled, Mode=TwoWay}"
                        IsEnabled="{Binding CanToggleAutoComplete}"
                        ToolTip="자동완성 (유니코드 직접 입력) 켜기/끄기">
                    <TextBlock Text="AC" FontWeight="Bold" FontSize="12"/>
                </ToggleButton>

                <!-- T-7.2: 접기/펼치기 버튼 -->
                <Button x:Name="CollapseButton" Width="32" Height="28"
                        HorizontalAlignment="Right" Margin="0,0,32,0"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Click="CollapseButton_Click"
                        ToolTip="접기 / 펼치기">
                    <TextBlock x:Name="CollapseIcon" Text="▲" FontSize="10"/>
                </Button>

                <!-- T-7.2: 닫기 버튼 → 트레이로 숨기기 -->
                <Button x:Name="CloseButton" Width="32" Height="28"
                        HorizontalAlignment="Right"
                        Background="Transparent" Foreground="{DynamicResource TitleFg}"
                        BorderThickness="0" Cursor="Hand"
                        Click="CloseButton_Click"
                        ToolTip="닫기 (트레이로 숨김)">
                    <TextBlock Text="✕" FontSize="14"/>
                </Button>
            </Grid>

            <!-- T-9.3: 자동 완성 제안 바 (제안이 있을 때만 표시) -->
            <views:SuggestionBar
                DockPanel.Dock="Top"
                DataContext="{Binding AutoComplete}"
                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>

            <!-- T-2.10: UAC 권한 경고 배너 (Auto 높이, 숨김 시 공간 없음) -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource ElevatedWarningBg}" CornerRadius="4"
                    Padding="12,6"
                    Visibility="{Binding Keyboard.ShowElevatedWarning, Converter={StaticResource BoolToVis}}">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ElevatedWarningFg}"
                           Text="키보드 보안 프로그램이나 관리자 권한 앱에서 입력이 차단되었습니다. AltKey를 관리자 권한으로 실행해 보세요."/>
            </Border>

            <!-- T-3.7 / T-4.10: 키보드 렌더링 (나머지 공간 채우기) -->
            <Border x:Name="KeyboardBorder"
                    Background="{DynamicResource KeyboardBg}"
                    CornerRadius="0,0,8,8" Padding="6,4"
                    SizeChanged="KeyboardBorder_SizeChanged"
                    MouseLeftButtonDown="KeyboardBorder_MouseLeftButtonDown">
                <ItemsControl ItemsSource="{Binding Keyboard.Rows}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:KeyRowVm}">
                            <ItemsControl ItemsSource="{Binding Keys}"
                                          HorizontalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:KeySlotVm}">
                                 <controls:KeyButton
                                     Slot="{Binding}"
                                     ShowUpperCase="{Binding DataContext.Keyboard.ShowUpperCase,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     DisplayLabel="{Binding DisplayLabel}"
                                     IsDimmed="{Binding IsDimmed}"
                                     IsSticky="{Binding IsSticky}"
                                     IsLocked="{Binding IsLocked}"
                                     KeyUnit="{Binding DataContext.Keyboard.KeyUnit,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     DwellEnabled="{Binding DataContext.DwellEnabled,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     DwellTime="{Binding DataContext.DwellTimeMs,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     KeyRepeatEnabled="{Binding DataContext.KeyRepeatEnabled,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     KeyRepeatDelayMs="{Binding DataContext.KeyRepeatDelayMs,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     KeyRepeatIntervalMs="{Binding DataContext.KeyRepeatIntervalMs,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     Command="{Binding DataContext.Keyboard.KeyPressedCommand,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     CommandParameter="{Binding Slot}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

        </DockPanel>

        <!-- 우하단 리사이즈 그립 (T-1.9) — Grid에 직접 배치해 항상 최상단에 표시 -->
        <Thumb x:Name="ResizeGrip"
               Width="20" Height="20"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Cursor="SizeNWSE"
               Panel.ZIndex="5"
               DragStarted="ResizeGrip_DragStarted"
               DragDelta="ResizeGrip_DragDelta">
            <Thumb.Template>
                <ControlTemplate>
                    <Grid Background="Transparent">
                        <Path Data="M 10 2 L 18 2 L 18 10 M 10 10 L 18 10 L 18 18"
                              Stroke="{DynamicResource TitleFg}" StrokeThickness="1.5" Fill="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!-- T-8.3: 이모지 패널 오버레이 (헤더 바 바로 아래, 키보드 위에 표시) -->
        <views:EmojiPanel
            DataContext="{Binding Emoji}"
            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
            VerticalAlignment="Top"
            Margin="0,28,0,0"
            Panel.ZIndex="6"/>

        <!-- T-8.4: 클립보드 패널 오버레이 (헤더 바 바로 아래, 좌측 배치) -->
        <views:ClipboardPanel
            DataContext="{Binding Clipboard}"
            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
            Width="240"
            Margin="0,28,0,0"
            Panel.ZIndex="6"/>

        <!-- T-5.10: 설정 패널 오버레이 (키보드 전체 위에 표시) -->
        <views:SettingsView
            x:Name="SettingsPanel"
            DataContext="{Binding Settings}"
            Visibility="{Binding DataContext.IsSettingsOpen,
                RelativeSource={RelativeSource AncestorType=UserControl},
                Converter={StaticResource BoolToVis}}"
            Panel.ZIndex="10"
            Margin="8,4,8,4"/>

    </Grid>
</UserControl>
