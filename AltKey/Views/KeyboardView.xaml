<UserControl x:Class="AltKey.Views.KeyboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="320">
    <Grid>
        <!-- 상단 드래그 핸들 (T-1.5) -->
        <Border x:Name="DragHandle" Height="28" VerticalAlignment="Top"
                Background="Transparent"
                MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="AltKey" HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="12,0,0,0" Foreground="#CCC" FontSize="12"
                           IsHitTestVisible="False"/>
                <TextBlock Text="⋯  드래그하여 이동" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="11" Foreground="#AAA" IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- 우상단 닫기 버튼 -->
        <Button x:Name="CloseButton" Width="32" Height="28"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Background="Transparent" Foreground="#CCC"
                BorderThickness="0" Cursor="Hand"
                Click="CloseButton_Click"
                ToolTip="닫기 (Esc)">
            <TextBlock Text="✕" FontSize="14"/>
        </Button>

        <!-- 키보드 콘텐츠 영역 (플레이스홀더) -->
        <Border Margin="0,28,0,16" Background="#CC1A1A1A" CornerRadius="0,0,8,8">
            <TextBlock Text="Keyboard Layout Area" HorizontalAlignment="Center"
                       VerticalAlignment="Center" Foreground="#DDD" FontSize="16"/>
        </Border>

        <!-- 우하단 리사이즈 그립 (T-1.9) -->
        <Thumb x:Name="ResizeGrip"
               Width="20" Height="20"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Cursor="SizeNWSE"
               DragDelta="ResizeGrip_DragDelta">
            <Thumb.Template>
                <ControlTemplate>
                    <Grid Background="Transparent">
                        <Path Data="M 10 2 L 18 2 L 18 10 M 10 10 L 18 10 L 18 18"
                              Stroke="#555" StrokeThickness="1.5" Fill="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</UserControl>
